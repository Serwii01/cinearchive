{
  "name": "cine-archive",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file-if-exists=.env node_modules/astro/astro.js dev",
    "build": "node --env-file-if-exists=.env node_modules/astro/astro.js build",
    "preview": "node --env-file-if-exists=.env node_modules/astro/astro.js preview",
    "astro": "astro",
    "start": "node --env-file-if-exists=.env ./dist/server/entry.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:deploy": "node --env-file-if-exists=.env scripts/migrate.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.5",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.4",
    "@fontsource-variable/eb-garamond": "^5.1.1",
    "@fontsource/geist-sans": "^5.1.0",
    "@fontsource/space-mono": "^5.1.0",
    "astro": "^5.1.1",
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.45.2",
    "leaflet": "^1.9.4",
    "pg": "^8.22.0",
    "tailwindcss": "^3.4.17",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "vitest": "^4.1.9"
  }
}
