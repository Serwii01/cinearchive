# ───────────────────────────────────────────────────────────────────────────
# Plantilla de variables de entorno. Copia este archivo a `.env` y rellénalo.
# El archivo `.env` NUNCA se versiona (está en .gitignore). Ninguna de estas
# variables lleva prefijo PUBLIC_, así que jamás llegan al navegador.
# ───────────────────────────────────────────────────────────────────────────

# --- Dominio y TLS (para Caddy) ---
DOMAIN=cine-archive.tudominio.com
EMAIL=tu-correo@ejemplo.com
# URL pública completa (se usa para SEO y para los callbacks de OAuth).
SITE_URL=https://cine-archive.tudominio.com
BETTER_AUTH_URL=https://cine-archive.tudominio.com

# --- Base de datos PostgreSQL (servicio db de docker-compose) ---
POSTGRES_USER=cine
POSTGRES_PASSWORD=cambia-esta-password
POSTGRES_DB=cine_archive

# --- Secreto de sesión (genera uno con: openssl rand -base64 32) ---
BETTER_AUTH_SECRET=genera-un-secreto-largo-y-aleatorio

# --- APIs de cine (planes gratuitos) ---
# TMDB: https://www.themoviedb.org/settings/api  (API Key v3)
TMDB_API_KEY=
# OMDb: https://www.omdbapi.com/apikey.aspx  (límite gratis 1000/día → se cachea)
OMDB_API_KEY=
# Watchmode (dónde ver): https://api.watchmode.com/  (gratis 1000/mes → se cachea)
WATCHMODE_API_KEY=

# --- Login social (opcional; deja en blanco para desactivarlo) ---
# Google:  https://console.cloud.google.com/  (Credenciales OAuth 2.0)
#   Redirect URI: https://TU_DOMINIO/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub:  https://github.com/settings/developers  (OAuth App)
#   Callback URL: https://TU_DOMINIO/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Panel de administración ---
# Correos (separados por comas) que pueden entrar en /admin tras iniciar sesión.
ADMIN_EMAILS=

# --- Email transaccional (recuperar contraseña; opcional) ---
# Sin esto, el reset de contraseña no envía correos (el login social sigue OK).
# Resend: https://resend.com  (verifica tu dominio para el remitente)
RESEND_API_KEY=
EMAIL_FROM=
