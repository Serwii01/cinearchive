---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Ticker from '../components/Ticker.astro';
import { getLangFromUrl, languages, useTranslations, defaultLang, type Lang } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
}

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { title, description } = Astro.props;
const pageTitle = title ? `${title} — ${t('site.title')}` : `${t('site.title')} — ${t('site.tagline')}`;
const pageDesc = description ?? t('site.description');

const canonical = new URL(Astro.url.pathname, Astro.site);
// Toda página bajo /{lang}/ existe en todos los idiomas con la misma ruta:
// las alternativas hreflang se obtienen intercambiando el prefijo.
const langs = Object.keys(languages) as Lang[];
const langPrefix = new RegExp(`^/(${langs.join('|')})(?=/|$)`);
const alternates = langPrefix.test(Astro.url.pathname)
  ? langs.map((code) => ({
      code,
      href: new URL(Astro.url.pathname.replace(langPrefix, `/${code}`), Astro.site).href,
    }))
  : [];
const ogLocales: Record<Lang, string> = { es: 'es_ES', en: 'en_US', gl: 'gl_ES', eu: 'eu_ES', ca: 'ca_ES' };
const ogImage = new URL('/og.png', Astro.site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Adelanta la conexión a los hosts de imágenes para acelerar la carga */}
    <link rel="preconnect" href="https://image.tmdb.org" />
    <link rel="dns-prefetch" href="https://archive.org" />
    {/* Aplica el tema guardado antes de pintar (evita parpadeo). */}
    <script is:inline src="/theme-init.js"></script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical.href} />
    {alternates.map((alt) => <link rel="alternate" hreflang={alt.code} href={alt.href} />)}
    {alternates.length > 0 && (
      <link rel="alternate" hreflang="x-default" href={alternates.find((a) => a.code === defaultLang)!.href} />
    )}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={t('site.title')} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:locale" content={ogLocales[lang]} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t('site.title')} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="flex min-h-screen flex-col">
    <Ticker />
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
