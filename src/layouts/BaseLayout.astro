---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Ticker from '../components/Ticker.astro';
import ProfileNudge from '../components/ProfileNudge.astro';
import { getLangFromUrl, languages, useTranslations, defaultLang, type Lang } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  /** Imagen social (og/twitter). Absoluta o ruta relativa a `site`. Default: /og.png. */
  image?: string;
  /** Si es true, la página no se indexa (páginas privadas/finas). */
  noindex?: boolean;
  /** Tipo Open Graph: 'website' (default) o 'article' para fichas/dosieres. */
  ogType?: 'website' | 'article';
  /** Datos estructurados schema.org; se serializan como JSON-LD (uno o varios). */
  jsonLd?: object | object[];
}

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { title, description, image, noindex, ogType = 'website', jsonLd } = Astro.props;
const pageTitle = title ? `${title} — ${t('site.title')}` : `${t('site.title')} — ${t('site.tagline')}`;
const pageDesc = description ?? t('site.description');

// Escapa `<` para que un `</script>` en el contenido no rompa el bloque JSON-LD.
const jsonLdList = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const serializeLd = (data: object): string => JSON.stringify(data).replace(/</g, '\\u003c');

const canonical = new URL(Astro.url.pathname, Astro.site);
// Toda página bajo /{lang}/ existe en todos los idiomas con la misma ruta:
// las alternativas hreflang se obtienen intercambiando el prefijo.
const langs = Object.keys(languages) as Lang[];
const langPrefix = new RegExp(`^/(${langs.join('|')})(?=/|$)`);
const alternates = langPrefix.test(Astro.url.pathname)
  ? langs.map((code) => ({
      code,
      href: new URL(Astro.url.pathname.replace(langPrefix, `/${code}`), Astro.site).href,
    }))
  : [];
const ogLocales: Record<Lang, string> = { es: 'es_ES', en: 'en_US', gl: 'gl_ES', eu: 'eu_ES', ca: 'ca_ES' };
const ogImage = image
  ? (/^https?:\/\//.test(image) ? image : new URL(image, Astro.site).href)
  : new URL('/og.png', Astro.site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Adelanta la conexión a los hosts de imágenes para acelerar la carga */}
    <link rel="preconnect" href="https://image.tmdb.org" />
    <link rel="dns-prefetch" href="https://archive.org" />
    {/* Aplica el tema guardado antes de pintar (evita parpadeo). */}
    <script is:inline src="/theme-init.js"></script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical.href} />
    {alternates.map((alt) => <link rel="alternate" hreflang={alt.code} href={alt.href} />)}
    {alternates.length > 0 && (
      <link rel="alternate" hreflang="x-default" href={alternates.find((a) => a.code === defaultLang)!.href} />
    )}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={t('site.title')} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:locale" content={ogLocales[lang]} />
    <meta property="og:image" content={ogImage} />
    {/* Solo declaramos dimensiones para la imagen por defecto (1200×630 conocido);
        para imágenes por página deja que la plataforma lea el tamaño real. */}
    {!image && <meta property="og:image:width" content="1200" />}
    {!image && <meta property="og:image:height" content="630" />}
    <meta property="og:image:alt" content={t('site.title')} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    {jsonLdList.map((data) => (
      <script type="application/ld+json" set:html={serializeLd(data)} />
    ))}
  </head>
  <body class="flex min-h-screen flex-col">
    <Ticker />
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <ProfileNudge />
  </body>
</html>
