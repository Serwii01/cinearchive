---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Ticker from '../components/Ticker.astro';
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  /** ruta del idioma alterno para hreflang/conmutador, p.ej. "/en/archive" */
  altPath?: string;
}

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { title, description, altPath } = Astro.props;
const pageTitle = title ? `${title} — ${t('site.title')}` : `${t('site.title')} — ${t('site.tagline')}`;
const pageDesc = description ?? t('site.description');

const canonical = new URL(Astro.url.pathname, Astro.site);
const altLang = lang === 'es' ? 'en' : 'es';
const altHref = altPath ? new URL(altPath, Astro.site).href : undefined;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Aplica el tema guardado antes de pintar (evita parpadeo). */}
    <script is:inline src="/theme-init.js"></script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical.href} />
    {altHref && <link rel="alternate" hreflang={altLang} href={altHref} />}
    {altHref && <link rel="alternate" hreflang={lang} href={canonical.href} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="flex min-h-screen flex-col">
    <Ticker />
    <Header altPath={altPath} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
