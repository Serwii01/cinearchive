---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { languages, useTranslations, localizePath, type Lang, type UIKey } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

interface Item {
  path: string;
  label: UIKey;
  desc: UIKey;
}
interface Group {
  heading: UIKey;
  needsAccount?: boolean;
  items: Item[];
}

const groups: Group[] = [
  {
    heading: 'nav.films',
    items: [
      { path: '', label: 'nav.home', desc: 'info.home' },
      { path: 'films', label: 'nav.films', desc: 'info.films' },
      { path: 'discover', label: 'nav.discover', desc: 'discover.intro' },
      { path: 'cinema', label: 'nav.cinema', desc: 'cinema.intro' },
      { path: 'collections', label: 'nav.collections', desc: 'collections.intro' },
      { path: 'figures', label: 'nav.figures', desc: 'figures.intro' },
      { path: 'atlas', label: 'nav.atlas', desc: 'atlas.intro' },
    ],
  },
  {
    heading: 'nav.archive',
    items: [
      { path: 'archive', label: 'nav.archive', desc: 'archive.intro' },
      { path: 'library', label: 'nav.library', desc: 'library.intro' },
      { path: 'glossary', label: 'nav.glossary', desc: 'glossary.intro' },
      { path: 'timeline', label: 'nav.timeline', desc: 'timeline.intro' },
      { path: 'awards', label: 'nav.awards', desc: 'awards.intro' },
    ],
  },
  {
    heading: 'nav.account',
    needsAccount: true,
    items: [
      { path: 'account', label: 'nav.account', desc: 'info.account' },
      { path: 'watchlist', label: 'nav.watchlist', desc: 'info.watchlist' },
      { path: 'recommendations', label: 'nav.recommendations', desc: 'recs.intro' },
      { path: 'stats', label: 'nav.stats', desc: 'stats.intro' },
    ],
  },
  {
    heading: 'info.gSocial',
    needsAccount: true,
    items: [
      { path: 'account', label: 'profile.yours', desc: 'info.profile' },
      { path: 'search', label: 'search.title', desc: 'info.search' },
    ],
  },
  {
    heading: 'info.gProject',
    items: [
      { path: 'about', label: 'nav.about', desc: 'info.manifesto' },
      { path: 'accessibility', label: 'nav.accessibility', desc: 'info.accessibility' },
      { path: 'privacy', label: 'nav.privacy', desc: 'info.privacy' },
      { path: 'terms', label: 'nav.terms', desc: 'info.terms' },
    ],
  },
];
---

<BaseLayout
  title={t('info.title')}
  description={t('info.intro')}
>
  <section class="frame py-12">
    <header class="border-b border-ink pb-6">
      <span class="label">{t('nav.info')}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{t('info.title')}</h1>
      <p class="mt-4 max-w-2xl text-body-lg text-charcoal">{t('info.intro')}</p>
    </header>

    <div class="mt-10 flex flex-col gap-12">
      {
        groups.map((g) => (
          <div>
            <h2 class="flex flex-wrap items-baseline gap-3 border-b border-ink pb-2 text-headline-lg text-ink">
              {t(g.heading)}
              {g.needsAccount && <span class="label text-muted">{t('info.needsAccount')}</span>}
            </h2>
            <ul class="mt-4 grid grid-cols-1 gap-px border border-ink bg-ink sm:grid-cols-2">
              {g.items.map((it) => (
                <a href={localizePath(lang, it.path)} class="group flex flex-col bg-surface p-4 no-underline transition-colors hover:bg-film-white">
                  <span class="font-display text-headline-md leading-tight text-ink transition-colors group-hover:text-muted">{t(it.label)} →</span>
                  <span class="mt-1 text-body-md text-charcoal">{t(it.desc)}</span>
                </a>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
