---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { languages, useTranslations, localizePath, type Lang, type UIKey } from '../../i18n/ui';
import { faqLd } from '../../lib/seo';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

// Cada pregunta es un par de claves i18n (faq.qN / faq.aN). Añadir una nueva es
// solo sumar el par aquí y sus traducciones en los 5 idiomas de ui.ts.
const qa: { q: UIKey; a: UIKey }[] = Array.from({ length: 10 }, (_, i) => ({
  q: `faq.q${i + 1}` as UIKey,
  a: `faq.a${i + 1}` as UIKey,
}));

// Datos estructurados FAQPage (rich result de Google) con las Q/A traducidas.
const faqJsonLd = faqLd(qa.map((item) => ({ question: t(item.q), answer: t(item.a) })));
---

<BaseLayout title={t('faq.title')} description={t('faq.intro')} jsonLd={faqJsonLd}>
  <section class="frame py-12">
    <header class="border-b border-ink pb-6">
      <span class="label">{t('nav.faq')}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{t('faq.title')}</h1>
      <p class="mt-4 max-w-2xl text-body-lg text-charcoal">{t('faq.intro')}</p>
    </header>

    <div class="mt-10 grid grid-cols-1 gap-px border border-ink bg-ink">
      {
        qa.map((item) => (
          <details class="group bg-surface open:bg-film-white">
            <summary class="flex cursor-pointer items-baseline justify-between gap-4 px-4 py-4 no-underline">
              <span class="font-display text-headline-md leading-tight text-ink transition-colors group-hover:text-muted">
                {t(item.q)}
              </span>
              <span class="mt-1 select-none font-mono text-body-lg text-muted transition-transform group-open:rotate-45" aria-hidden="true">
                +
              </span>
            </summary>
            <p class="max-w-2xl px-4 pb-5 text-body-md text-charcoal">{t(item.a)}</p>
          </details>
        ))
      }
    </div>

    <div class="mt-10 border-t border-ink pt-6">
      <p class="text-body-md text-charcoal">
        {t('faq.stillHelp')}{' '}
        <a href={localizePath(lang, 'info')} class="font-medium text-ink underline underline-offset-2 hover:text-muted">
          {t('faq.stillHelpLink')} →
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
