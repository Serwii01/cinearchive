---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Avatar from '../../../components/Avatar.astro';
import { normalizeLang, useTranslations, localizePath, formatDate, type Lang } from '../../../i18n/ui';
import { db } from '../../../db/client';
import { userFilms, userLists, userListFilms } from '../../../db/schema';
import { and, desc, eq, isNotNull, or, count, inArray } from 'drizzle-orm';
import { getFilmsBrief, type FilmBrief } from '../../../lib/films';
import {
  getProfileByUsername,
  followState,
  canViewActivity,
  followCounts,
  getMyProfile,
  instagramUrl,
} from '../../../lib/social';

export const prerender = false;

const lang = normalizeLang(Astro.params.lang);
const t = useTranslations(lang);
const viewer = Astro.locals.user;

const target = await getProfileByUsername(Astro.params.username ?? '');

if (!target) {
  return new Response(null, { status: 404 });
}

const state = await followState(viewer?.id ?? null, target.userId);
const isSelf = state === 'self';
const canView = canViewActivity(viewer?.id ?? null, target, state);
const counts = await followCounts(target.userId);
// Para seguir hace falta tener perfil propio (username).
const viewerHasProfile = viewer ? !!(await getMyProfile(viewer.id)) : false;

// Actividad visible: reseñas (películas con nota o valoración), colecciones por
// estado (favoritas y pendientes, públicas por defecto) y listas públicas.
let reviews: { tmdbId: number; rating: number | null; note: string | null; reviewedAt: Date }[] = [];
let favorites: number[] = [];
let watchlist: number[] = [];
let lists: { id: string; name: string; count: number; films: number[] }[] = [];
let briefs = new Map<number, FilmBrief>();

if (canView) {
  const reviewRows = await db
    .select({
      tmdbId: userFilms.tmdbId,
      rating: userFilms.rating,
      note: userFilms.note,
      reviewedAt: userFilms.reviewedAt,
      updatedAt: userFilms.updatedAt,
    })
    .from(userFilms)
    .where(and(eq(userFilms.userId, target.userId), or(isNotNull(userFilms.rating), isNotNull(userFilms.note))))
    .orderBy(desc(userFilms.updatedAt))
    .limit(60);
  reviews = reviewRows.map((r) => ({ ...r, reviewedAt: r.reviewedAt ?? r.updatedAt }));

  // Favoritas (flag propio) y pendientes (estado). Públicas por defecto dentro
  // del perfil visible. Las filas antiguas con status='favorite' se normalizan.
  const statusRows = await db
    .select({ tmdbId: userFilms.tmdbId, status: userFilms.status, favorite: userFilms.favorite })
    .from(userFilms)
    .where(
      and(
        eq(userFilms.userId, target.userId),
        or(eq(userFilms.favorite, true), inArray(userFilms.status, ['favorite', 'want'])),
      ),
    )
    .orderBy(desc(userFilms.updatedAt));
  favorites = statusRows.filter((r) => r.favorite || r.status === 'favorite').map((r) => r.tmdbId);
  watchlist = statusRows.filter((r) => r.status === 'want').map((r) => r.tmdbId);

  const publicLists = await db
    .select({ id: userLists.id, name: userLists.name })
    .from(userLists)
    .where(and(eq(userLists.userId, target.userId), eq(userLists.isPublic, true)))
    .orderBy(userLists.createdAt);

  const listFilmMap = new Map<string, number[]>();
  if (publicLists.length) {
    const rows = await db
      .select({ listId: userListFilms.listId, tmdbId: userListFilms.tmdbId })
      .from(userListFilms)
      .where(inArray(userListFilms.listId, publicLists.map((l) => l.id)))
      .orderBy(desc(userListFilms.addedAt));
    for (const r of rows) {
      const arr = listFilmMap.get(r.listId) ?? [];
      arr.push(r.tmdbId);
      listFilmMap.set(r.listId, arr);
    }
  }
  lists = publicLists.map((l) => ({ id: l.id, name: l.name, films: listFilmMap.get(l.id) ?? [], count: (listFilmMap.get(l.id) ?? []).length }));

  const allIds = [
    ...new Set([...reviews.map((r) => r.tmdbId), ...favorites, ...watchlist, ...lists.flatMap((l) => l.films)]),
  ];
  briefs = await getFilmsBrief(allIds, lang);
}

const title = `@${target.username}`;
// Enlace canónico (dominio real). Astro.url tras el proxy da localhost, por eso
// se usa Astro.site (SITE_URL / cinearchive.es).
const shareUrl = new URL(localizePath(lang, `u/${target.username}`), Astro.site ?? Astro.url).href;
---

<BaseLayout title={title}>
  <section class="frame py-12">
    {/* Cabecera del perfil */}
    <header class="flex flex-col gap-6 border-b border-ink pb-8 sm:flex-row sm:items-start sm:justify-between">
      <div class="flex items-start gap-5">
        {target.avatarType ? (
          <button
            type="button"
            id="avatar-view"
            class="shrink-0 cursor-zoom-in border-0 bg-transparent p-0"
            aria-label={t('profile.viewPhoto')}
          >
            <Avatar userId={target.userId} name={target.name} hasAvatar size={96} class="h-20 w-20 sm:h-24 sm:w-24" />
          </button>
        ) : (
          <Avatar userId={target.userId} name={target.name} hasAvatar={false} size={96} class="h-20 w-20 sm:h-24 sm:w-24" />
        )}
        <div class="min-w-0">
          <h1 class="text-display-mobile md:text-display-lg">{target.name}</h1>
          <p class="mt-1 font-mono text-body-md text-muted">@{target.username}</p>
          {target.isPrivate && <p class="label mt-2 inline-block border border-ink px-2 py-1">{t('profile.private')}</p>}
          {target.bio && <p class="mt-3 max-w-prose text-body-md text-charcoal">{target.bio}</p>}
          {target.instagram && (
            <p class="mt-3">
              <a
                href={instagramUrl(target.instagram)}
                target="_blank"
                rel="me noopener noreferrer"
                class="inline-flex items-center gap-2 font-mono text-meta-data text-ink no-underline hover:text-ochre"
              >
                <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><line x1="17.5" y1="6.5" x2="17.5" y2="6.5"></line></svg>
                @{target.instagram}
              </a>
            </p>
          )}
          <div class="mt-4 flex gap-6 font-mono text-meta-data text-ink">
            {canView ? (
              <>
                <button type="button" data-conn="followers" class="text-left no-underline hover:text-muted"><strong class="text-headline-md">{counts.followers}</strong> {t('profile.followers')}</button>
                <button type="button" data-conn="following" class="text-left no-underline hover:text-muted"><strong class="text-headline-md">{counts.following}</strong> {t('profile.following')}</button>
              </>
            ) : (
              <>
                <span><strong class="text-headline-md">{counts.followers}</strong> {t('profile.followers')}</span>
                <span><strong class="text-headline-md">{counts.following}</strong> {t('profile.following')}</span>
              </>
            )}
          </div>
        </div>
      </div>

      {/* Acción: seguir / editar / iniciar sesión + compartir */}
      <div class="flex shrink-0 flex-col items-stretch gap-2 sm:items-end">
        {isSelf ? (
          <a href={localizePath(lang, 'account')} class="btn btn-secondary">{t('profile.editProfile')}</a>
        ) : viewer && !viewerHasProfile ? (
          <a href={localizePath(lang, 'account')} class="btn btn-secondary">{t('profile.createToFollow')}</a>
        ) : viewer ? (
          <button
            id="follow-btn"
            type="button"
            data-username={target.username}
            data-state={state}
            data-follow={t('profile.follow')}
            data-requested={t('profile.requested')}
            data-following={t('profile.followingBtn')}
            class="btn btn-primary"
          >{state === 'accepted' ? t('profile.followingBtn') : state === 'pending' ? t('profile.requested') : t('profile.follow')}</button>
        ) : (
          <a href={`${localizePath(lang, 'login')}?next=${encodeURIComponent(Astro.url.pathname)}`} class="btn btn-secondary">{t('profile.loginToFollow')}</a>
        )}
        <button
          id="share-profile"
          type="button"
          data-url={shareUrl}
          data-share-title={title}
          data-copied={t('profile.linkCopied')}
          class="btn btn-secondary inline-flex items-center justify-center gap-2"
        >
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.6" y1="13.5" x2="15.4" y2="17.5"></line><line x1="15.4" y1="6.5" x2="8.6" y2="10.5"></line></svg>
          {t('profile.share')}
        </button>
      </div>
    </header>

    {!canView ? (
      <div class="mt-12 border border-ink bg-surface p-8 text-center">
        <p class="font-display text-headline-lg text-ink">{t('profile.private')}</p>
        <p class="mt-2 font-mono text-body-md text-muted">{t('profile.privateLocked')}</p>
      </div>
    ) : (
      <>
        {/* Reseñas */}
        <div class="mt-12">
          <h2 class="border-b border-ink pb-2 text-headline-lg text-ink">{t('profile.reviews')} <span class="label">· {reviews.length}</span></h2>
          {reviews.length === 0 ? (
            <p class="mt-4 font-mono text-body-md text-muted">{t('profile.noReviews')}</p>
          ) : (
            <div class="mt-4 grid grid-cols-1 gap-px border border-ink bg-ink sm:grid-cols-2 lg:grid-cols-3">
              {reviews.map((r) => {
                const b = briefs.get(r.tmdbId);
                return (
                  <a href={localizePath(lang, `u/${target.username}/review/${r.tmdbId}`)} class="flex gap-3 bg-surface p-3 no-underline hover:bg-film-white">
                    <div class="h-24 w-16 shrink-0 border border-ink bg-charcoal">
                      {b?.poster && <img src={b.poster} alt={b.title} class="h-full w-full object-cover" />}
                    </div>
                    <div class="min-w-0">
                      <p class="font-display text-headline-md leading-tight text-ink">{b?.title ?? `#${r.tmdbId}`}</p>
                      <p class="font-mono text-meta-data text-muted">{[b?.director, b?.year].filter(Boolean).join(' · ')}</p>
                      {r.rating && <p class="mt-1 font-mono text-meta-data text-ink">{'★'.repeat(r.rating)}<span class="text-outline-variant">{'★'.repeat(5 - r.rating)}</span></p>}
                      {r.note && <p class="mt-1 line-clamp-3 text-body-md text-charcoal/80">{r.note}</p>}
                      <p class="mt-1 font-mono text-meta-data text-outline">{formatDate(r.reviewedAt, lang)}</p>
                    </div>
                  </a>
                );
              })}
            </div>
          )}
        </div>

        {/* Colecciones por estado: favoritas y pendientes (públicas por defecto) */}
        {([
          { key: 'fav', label: t('watchlist.favorite'), ids: favorites },
          { key: 'want', label: t('watchlist.want'), ids: watchlist },
        ] as const).map((col) =>
          col.ids.length > 0 ? (
            <div class="mt-12">
              <h2 class="border-b border-ink pb-2 text-headline-lg text-ink">{col.label} <span class="label">· {col.ids.length}</span></h2>
              <div class="mt-4 grid grid-cols-4 gap-px border border-ink bg-ink sm:grid-cols-6 lg:grid-cols-9">
                {col.ids.slice(0, 27).map((id) => {
                  const b = briefs.get(id);
                  return (
                    <a href={localizePath(lang, `film/${id}`)} class="block bg-surface no-underline" title={b?.title}>
                      <div class="aspect-[2/3] w-full bg-charcoal">
                        {b?.poster ? (
                          <img src={b.poster} alt={b?.title ?? ''} loading="lazy" decoding="async" class="h-full w-full object-cover" />
                        ) : (
                          <div class="film-grain h-full w-full"></div>
                        )}
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          ) : null,
        )}

        {/* Listas públicas */}
        <div class="mt-12">
          <h2 class="border-b border-ink pb-2 text-headline-lg text-ink">{t('profile.publicLists')} <span class="label">· {lists.length}</span></h2>
          {lists.length === 0 ? (
            <p class="mt-4 font-mono text-body-md text-muted">{t('profile.noLists')}</p>
          ) : (
            lists.map((l) => (
              <div class="mt-6">
                <h3 class="font-display text-headline-md text-ink">
                  <a href={`${localizePath(lang, `lists/${l.id}`)}?from=profile`} class="no-underline hover:text-ochre">{l.name}</a>
                  <span class="label">· {l.count}</span>
                </h3>
                <div class="mt-3 grid grid-cols-4 gap-px border border-ink bg-ink sm:grid-cols-6 lg:grid-cols-9">
                  {l.films.slice(0, 18).map((id) => {
                    const b = briefs.get(id);
                    return (
                      <a href={localizePath(lang, `film/${id}`)} class="block bg-surface no-underline" title={b?.title}>
                        <div class="aspect-[2/3] w-full bg-charcoal">
                          {b?.poster ? (
                            <img src={b.poster} alt={b?.title ?? ''} loading="lazy" decoding="async" class="h-full w-full object-cover" />
                          ) : (
                            <div class="film-grain h-full w-full"></div>
                          )}
                        </div>
                      </a>
                    );
                  })}
                </div>
                <a href={`${localizePath(lang, `lists/${l.id}`)}?from=profile`} class="mt-2 inline-block font-mono text-meta-data text-ink no-underline hover:text-ochre">{t('lists.viewList')} →</a>
              </div>
            ))
          )}
        </div>
      </>
    )}
  </section>

  {/* Modal de seguidores / seguidos */}
  <div
    id="conn-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-ink/60 p-4 sm:p-8"
    data-username={target.username}
    data-base={localizePath(lang, 'u')}
    data-followers={t('profile.followers')}
    data-following={t('profile.following')}
    data-empty-followers={t('profile.noFollowers')}
    data-empty-following={t('profile.noFollowing')}
    data-close={t('profile.close')}
    data-private={t('profile.private')}
    data-loading={t('profile.loading')}
    data-self={isSelf ? '1' : '0'}
    data-remove={t('profile.removeFollower')}
    data-unfollow={t('profile.unfollow')}
    data-confirm={t('profile.confirm')}
    data-cancel={t('profile.cancel')}
  >
    <div class="w-full max-w-md border-2 border-ink bg-surface" role="dialog" aria-modal="true" aria-labelledby="conn-title">
      <header class="flex items-center justify-between border-b-2 border-ink px-4 py-3">
        <h2 id="conn-title" class="font-display text-headline-md text-ink">—</h2>
        <button id="conn-close" type="button" aria-label={t('profile.close')} class="flex h-8 w-8 items-center justify-center border border-ink font-mono text-headline-md leading-none transition-colors hover:bg-ink hover:text-white">✕</button>
      </header>
      <ul id="conn-list" class="max-h-[60vh] divide-y divide-outline overflow-y-auto"></ul>
    </div>
  </div>

  {/* Visor de la foto de perfil en grande */}
  {target.avatarType && (
    <div id="photo-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-ink/80 p-4" data-close={t('profile.close')}>
      <button id="photo-close" type="button" aria-label={t('profile.close')} class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center border-2 border-white font-mono text-headline-md leading-none text-white transition-colors hover:bg-white hover:text-ink">✕</button>
      <img src={`/api/avatar/${target.userId}`} alt={target.name} class="max-h-[85vh] max-w-full border-2 border-white object-contain" />
    </div>
  )}
</BaseLayout>

<script>
  const btn = document.getElementById('follow-btn') as HTMLButtonElement | null;
  if (btn) {
    const labels = {
      none: btn.dataset.follow!,
      pending: btn.dataset.requested!,
      accepted: btn.dataset.following!,
    };
    const render = (state: string) => {
      btn.textContent = labels[state as keyof typeof labels] ?? labels.none;
      btn.dataset.state = state;
    };
    btn.addEventListener('click', async () => {
      const current = btn.dataset.state || 'none';
      const username = btn.dataset.username;
      btn.disabled = true;
      try {
        // Si ya sigue o solicitó, el clic deja de seguir / cancela; si no, sigue.
        const method = current === 'none' ? 'POST' : 'DELETE';
        const res = await fetch('/api/follow', {
          method,
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ username }),
        });
        if (res.ok) {
          const data = await res.json();
          render(data.status ?? 'none');
        }
      } finally {
        btn.disabled = false;
      }
    });
  }

  // --- Modal de seguidores / seguidos ---
  const modal = document.getElementById('conn-modal') as HTMLElement | null;
  if (modal) {
    const title = document.getElementById('conn-title') as HTMLElement;
    const list = document.getElementById('conn-list') as HTMLElement;
    const username = modal.dataset.username!;
    const base = modal.dataset.base!;
    const esc = (s: string) =>
      s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));

    const self = modal.dataset.self === '1';
    let lastFocus: HTMLElement | null = null;
    let currentType: 'followers' | 'following' = 'followers';
    const isOpen = () => modal.classList.contains('flex');

    const close = () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
      lastFocus?.focus();
    };

    // Botón de acción del propietario (eliminar seguidor / dejar de seguir).
    const actBtn = (label: string) =>
      `<button type="button" data-act class="label border border-ink px-2 py-1 transition-colors hover:bg-error hover:text-white">${esc(label)}</button>`;

    const updateCount = (type: 'followers' | 'following', delta: number) => {
      const el = document.querySelector(`[data-conn="${type}"] strong`);
      if (el) {
        const n = Math.max(0, (parseInt(el.textContent || '0', 10) || 0) + delta);
        el.textContent = String(n);
      }
    };

    type Conn = { id: string; username: string; name: string; isPrivate: boolean; hasAvatar: boolean };
    // Caché en memoria + peticiones en vuelo, para que reabrir sea instantáneo y
    // el prefetch (al pasar el ratón / en reposo) adelante la carga.
    const cache: Partial<Record<'followers' | 'following', Conn[]>> = {};
    const inflight: Partial<Record<'followers' | 'following', Promise<Conn[]>>> = {};

    const load = (type: 'followers' | 'following'): Promise<Conn[]> => {
      if (cache[type]) return Promise.resolve(cache[type]!);
      if (inflight[type]) return inflight[type]!;
      const p = fetch(`/api/users/${encodeURIComponent(username)}/connections?type=${type}`, {
        headers: { accept: 'application/json' },
      })
        .then((res) => (res.ok ? res.json() : { results: [] }))
        .then((data) => {
          const rows = (data.results ?? []) as Conn[];
          cache[type] = rows;
          delete inflight[type];
          return rows;
        })
        .catch(() => {
          delete inflight[type];
          return [] as Conn[];
        });
      inflight[type] = p;
      return p;
    };

    const renderRows = (type: 'followers' | 'following', rows: Conn[]) => {
      if (!rows.length) {
        const emptyMsg = type === 'followers' ? modal.dataset.emptyFollowers! : modal.dataset.emptyFollowing!;
        list.innerHTML = `<li class="px-4 py-6 text-center font-mono text-meta-data text-muted">${esc(emptyMsg)}</li>`;
        return;
      }
      const actionLabel = type === 'followers' ? modal.dataset.remove! : modal.dataset.unfollow!;
      list.innerHTML = rows
        .map((r) => {
          const initials = (r.name || '?').trim().split(/\s+/).slice(0, 2).map((w) => w[0]?.toUpperCase() ?? '').join('');
          const avatar = r.hasAvatar
            ? `<img src="/api/avatar/${encodeURIComponent(r.id)}" alt="" class="h-full w-full object-cover" loading="lazy">`
            : `<span class="font-display text-body-md leading-none">${esc(initials)}</span>`;
          const lock = r.isPrivate ? ' · 🔒' : '';
          // Solo el propietario ve la acción (y nunca sobre sí mismo, que no aparece aquí).
          const action = self
            ? `<span class="flex shrink-0 items-center gap-1 pr-3" data-actbox data-uid="${esc(r.id)}" data-uname="${esc(r.username)}" data-type="${type}" data-label="${esc(actionLabel)}">${actBtn(actionLabel)}</span>`
            : '';
          return `<li class="flex items-center" data-row><a href="${base}/${encodeURIComponent(r.username)}" class="flex min-w-0 flex-1 items-center gap-3 px-4 py-3 no-underline hover:bg-film-white">
            <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center overflow-hidden border border-ink bg-ink text-white">${avatar}</span>
            <span class="min-w-0"><span class="block truncate font-display text-headline-md text-ink">${esc(r.name)}</span>
            <span class="block font-mono text-meta-data text-muted">@${esc(r.username)}${lock}</span></span>
          </a>${action}</li>`;
        })
        .join('');
    };

    const open = async (type: 'followers' | 'following') => {
      currentType = type;
      lastFocus = document.activeElement as HTMLElement;
      title.textContent = type === 'followers' ? modal.dataset.followers! : modal.dataset.following!;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      (document.getElementById('conn-close') as HTMLElement)?.focus();
      // Si ya está en caché, pinta al instante; si no, muestra "cargando" y espera.
      if (cache[type]) {
        renderRows(type, cache[type]!);
        return;
      }
      list.innerHTML = `<li class="px-4 py-6 text-center font-mono text-meta-data text-muted">${esc(modal.dataset.loading!)}</li>`;
      const rows = await load(type);
      if (currentType === type && isOpen()) renderRows(type, rows);
    };

    // Prefetch: al pasar el ratón/enfocar los contadores, y en reposo tras cargar.
    // Solo cuando los contadores son abribles (perfil visible), para no pedir de más.
    const connBtns = document.querySelectorAll<HTMLElement>('[data-conn]');
    connBtns.forEach((el) => {
      const type = el.dataset.conn as 'followers' | 'following';
      const warm = () => { load(type); };
      el.addEventListener('mouseenter', warm, { once: true });
      el.addEventListener('focus', warm, { once: true });
    });
    if (connBtns.length) {
      const idle = (cb: () => void) =>
        'requestIdleCallback' in window ? (window as any).requestIdleCallback(cb) : setTimeout(cb, 1200);
      idle(() => { load('followers'); load('following'); });
    }

    // Ejecuta la baja según el tipo (eliminar seguidor o dejar de seguir).
    const perform = async (type: string, uid: string, uname: string): Promise<boolean> => {
      try {
        const res =
          type === 'followers'
            ? await fetch('/api/follow/remove', {
                method: 'POST',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({ followerId: uid }),
              })
            : await fetch('/api/follow', {
                method: 'DELETE',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({ username: uname }),
              });
        return res.ok;
      } catch {
        return false;
      }
    };

    // Confirmación en dos pasos dentro de la propia fila (sin diálogos nativos).
    list.addEventListener('click', async (e) => {
      const el = e.target as HTMLElement;
      const box = el.closest('[data-actbox]') as HTMLElement | null;
      if (!box) return;
      e.preventDefault();
      if (el.closest('[data-act]')) {
        box.innerHTML =
          `<button type="button" data-yes class="label border border-error bg-error px-2 py-1 text-white">${esc(modal.dataset.confirm!)}</button>` +
          `<button type="button" data-no class="label border border-ink px-2 py-1 transition-colors hover:bg-ink hover:text-white">${esc(modal.dataset.cancel!)}</button>`;
        return;
      }
      if (el.closest('[data-no]')) {
        box.innerHTML = actBtn(box.dataset.label!);
        return;
      }
      if (el.closest('[data-yes]')) {
        box.querySelectorAll('button').forEach((b) => ((b as HTMLButtonElement).disabled = true));
        const ok = await perform(box.dataset.type!, box.dataset.uid!, box.dataset.uname!);
        if (ok) {
          const type = box.dataset.type as 'followers' | 'following';
          if (cache[type]) cache[type] = cache[type]!.filter((c) => c.id !== box.dataset.uid);
          box.closest('[data-row]')?.remove();
          updateCount(type, -1);
          if (!list.querySelector('[data-row]')) {
            const emptyMsg = currentType === 'followers' ? modal.dataset.emptyFollowers! : modal.dataset.emptyFollowing!;
            list.innerHTML = `<li class="px-4 py-6 text-center font-mono text-meta-data text-muted">${esc(emptyMsg)}</li>`;
          }
        } else {
          box.innerHTML = actBtn(box.dataset.label!);
        }
      }
    });

    document.querySelectorAll<HTMLElement>('[data-conn]').forEach((el) => {
      el.addEventListener('click', () => open(el.dataset.conn as 'followers' | 'following'));
    });
    document.getElementById('conn-close')?.addEventListener('click', close);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) close(); // clic en el fondo cierra
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) close();
    });
  }

  // --- Visor de la foto de perfil en grande ---
  const photoModal = document.getElementById('photo-modal') as HTMLElement | null;
  const photoTrigger = document.getElementById('avatar-view');
  if (photoModal && photoTrigger) {
    const openPhoto = () => {
      photoModal.classList.remove('hidden');
      photoModal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      (document.getElementById('photo-close') as HTMLElement)?.focus();
    };
    const closePhoto = () => {
      photoModal.classList.add('hidden');
      photoModal.classList.remove('flex');
      document.body.style.overflow = '';
    };
    photoTrigger.addEventListener('click', openPhoto);
    document.getElementById('photo-close')?.addEventListener('click', closePhoto);
    photoModal.addEventListener('click', (e) => {
      if (e.target === photoModal) closePhoto();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && photoModal.classList.contains('flex')) closePhoto();
    });
  }

  // --- Compartir perfil ---
  const shareBtn = document.getElementById('share-profile') as HTMLButtonElement | null;
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const url = shareBtn.dataset.url || window.location.href;
      // En móvil, hoja de compartir nativa (incluye "copiar enlace"); en escritorio,
      // copia directa al portapapeles con aviso.
      if (navigator.share) {
        try {
          await navigator.share({ title: shareBtn.dataset.shareTitle || document.title, url });
        } catch {
          /* cancelado por el usuario: sin acción */
        }
        return;
      }
      try {
        await navigator.clipboard.writeText(url);
      } catch {
        return;
      }
      const original = shareBtn.innerHTML;
      shareBtn.textContent = shareBtn.dataset.copied || 'OK';
      window.setTimeout(() => {
        shareBtn.innerHTML = original;
      }, 1500);
    });
  }
</script>
