---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { languages, useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { manifesto } from '../../data/manifesto';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const copy = manifesto[lang];
---

<BaseLayout title={t('about.title')}>
  <section class="frame py-12">
    <header class="border-b border-ink pb-8">
      <span class="label">{t('about.title')}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{t('site.title')}</h1>
      <p class="mt-6 max-w-3xl font-display text-headline-md text-ink">{copy.lead}</p>
    </header>

    <div class="grid grid-cols-1 gap-12 pt-10 md:grid-cols-12">
      <div class="prose-archive md:col-span-7 md:border-r md:border-ink md:pr-12">
        {copy.body.map((p) => <p>{p}</p>)}
      </div>

      <div class="md:col-span-5">
        <h2 class="label border-b border-ink pb-2">{copy.principlesTitle}</h2>
        <dl class="mt-4">
          {
            copy.principles.map(([term, desc], i) => (
              <div class:list={['py-4', i < copy.principles.length - 1 && 'border-b border-outline-variant']}>
                <dt class="font-display text-headline-md text-ink">{term}</dt>
                <dd class="mt-1 text-body-md text-charcoal">{desc}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>
</BaseLayout>
