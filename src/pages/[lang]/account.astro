---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { GENRES } from '../../data/genres';
import { db } from '../../db/client';
import { userPreferences } from '../../db/schema';
import { eq } from 'drizzle-orm';

const lang = (Astro.params.lang === 'en' ? 'en' : 'es') as Lang;
const t = useTranslations(lang);
const user = Astro.locals.user!; // middleware garantiza sesión

const [prefs] = await db
  .select()
  .from(userPreferences)
  .where(eq(userPreferences.userId, user.id))
  .limit(1);

const favGenres = new Set(prefs?.favoriteGenres ?? []);
const favDirectors = (prefs?.favoriteDirectors ?? []).join(', ');
const theme = prefs?.theme ?? 'light';
---

<BaseLayout title={t('account.title')}>
  <section class="frame py-12">
    <header class="border-b border-ink pb-6">
      <span class="label">{t('account.title')}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{user.name}</h1>
      <p class="mt-3 font-mono text-meta-data text-muted">{user.email}</p>
      <button id="logout" type="button" class="btn btn-secondary mt-5">{t('nav.logout')}</button>
    </header>

    <form id="prefs-form" class="mt-10 max-w-3xl" data-saved={t('account.saved')}>
      <h2 class="border-b border-ink pb-2 text-headline-lg text-ink">{t('account.preferences')}</h2>

      <!-- Géneros favoritos -->
      <fieldset class="mt-6">
        <legend class="label mb-3">{t('account.favoriteGenres')}</legend>
        <div class="flex flex-wrap gap-2">
          {GENRES.map((g) => (
            <label class="cursor-pointer">
              <input type="checkbox" name="genre" value={g.id} checked={favGenres.has(g.id)} class="peer sr-only" />
              <span class="label inline-block border border-ink px-3 py-2 transition-colors peer-checked:bg-ochre peer-checked:text-on-accent hover:bg-ink hover:text-white peer-checked:hover:bg-ochre peer-checked:hover:text-on-accent">
                {g[lang]}
              </span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- Directores favoritos -->
      <label class="mt-8 block">
        <span class="label mb-2 block">{t('account.favoriteDirectors')}</span>
        <input id="directors" type="text" value={favDirectors} placeholder="Tarkovsky, Varda, Ozu" class="w-full border border-ink bg-white px-3 py-2 font-body text-body-md focus:bg-film-white focus:outline-none" />
      </label>

      <!-- Tema -->
      <fieldset class="mt-8">
        <legend class="label mb-3">{t('account.theme')}</legend>
        <div class="inline-flex border border-ink">
          <label class="cursor-pointer">
            <input type="radio" name="theme" value="light" checked={theme === 'light'} class="peer sr-only" />
            <span class="label inline-block border-r border-ink px-4 py-2 peer-checked:bg-ink peer-checked:text-white">{t('account.themeLight')}</span>
          </label>
          <label class="cursor-pointer">
            <input type="radio" name="theme" value="dark" checked={theme === 'dark'} class="peer sr-only" />
            <span class="label inline-block px-4 py-2 peer-checked:bg-ink peer-checked:text-white">{t('account.themeDark')}</span>
          </label>
        </div>
      </fieldset>

      <div class="mt-8 flex items-center gap-4">
        <button type="submit" class="btn btn-primary">{t('account.save')}</button>
        <span data-msg class="font-mono text-meta-data text-muted"></span>
        <a href={localizePath(lang, 'recommendations')} class="label no-underline hover:text-ink">{t('nav.recommendations')} →</a>
      </div>
    </form>
  </section>
</BaseLayout>

<script>
  import { signOut } from '../../lib/auth-client';

  const lang = window.location.pathname.startsWith('/en') ? 'en' : 'es';

  document.getElementById('logout')?.addEventListener('click', async () => {
    await signOut();
    window.location.href = `/${lang}`;
  });

  const form = document.getElementById('prefs-form') as HTMLFormElement;
  const msg = form.querySelector('[data-msg]') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const genres = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="genre"]:checked')).map((i) =>
      Number(i.value),
    );
    const directors = (document.getElementById('directors') as HTMLInputElement).value
      .split(',')
      .map((s) => s.trim())
      .filter(Boolean);
    const theme = (form.querySelector('input[name="theme"]:checked') as HTMLInputElement)?.value || 'light';

    // Aplica el tema de inmediato y lo recuerda en este dispositivo.
    if (theme === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
    else document.documentElement.removeAttribute('data-theme');
    try {
      localStorage.setItem('theme', theme);
    } catch (e) {}
    document.dispatchEvent(new Event('themechange'));

    const res = await fetch('/api/me/preferences', {
      method: 'PATCH',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ locale: lang, favoriteGenres: genres, favoriteDirectors: directors, theme }),
    });
    if (res.ok) {
      msg.textContent = form.dataset.saved || 'OK';
      setTimeout(() => (msg.textContent = ''), 1800);
    }
  });
</script>
