---
export const prerender = false; // la película del día se obtiene en cada visita (cacheada por día)
import BaseLayout from '../../layouts/BaseLayout.astro';
import TmdbSearch from '../../components/TmdbSearch.astro';
import IssueCard from '../../components/IssueCard.astro';
import JournalCard from '../../components/JournalCard.astro';
import { periodicals, journals } from '../../lib/periodicals';
import { pdFilms, pdThumbUrl } from '../../lib/pdfilms';
import { books, bookCoverUrl } from '../../lib/library';
import { collections, collectionTitle, collectionBlurb } from '../../lib/collections';
import { figures } from '../../lib/figures';
import { profileUrl } from '../../lib/tmdb';
import { getFilmOfDay } from '../../lib/featured';
import { manifesto } from '../../data/manifesto';
import { normalizeLang, useTranslations, localizePath, type Lang } from '../../i18n/ui';

const lang = normalizeLang(Astro.params.lang);
const t = useTranslations(lang);

// Últimos números: el más reciente de 4 publicaciones DISTINTAS (sin repetir título).
const latestIssues = (() => {
  const sorted = periodicals.slice().sort((a, b) => b.year - a.year || a.title.localeCompare(b.title));
  const seen = new Set<string>();
  const out: typeof sorted = [];
  for (const p of sorted) {
    if (seen.has(p.title)) continue;
    seen.add(p.title);
    out.push(p);
    if (out.length === 4) break;
  }
  return out;
})();

// Selección repartida (variedad) de un conjunto, para los adelantos de portada.
const sample = <T,>(arr: T[], n: number): T[] => {
  if (arr.length <= n) return arr.slice();
  const step = arr.length / n;
  return Array.from({ length: n }, (_, i) => arr[Math.floor(i * step)]);
};
const cinemaPicks = sample(pdFilms, 4);
const collectionPicks = collections.slice(0, 3);
const figurePicks = sample(figures, 6);
const bookPicks = sample(books, 4);

const manifestoCopy = manifesto[lang];

const film = await getFilmOfDay(lang);
const overview = film?.overview && film.overview.length > 320 ? film.overview.slice(0, 317) + '…' : film?.overview;
---

<BaseLayout>
  {/* HERO — PELÍCULA DEL DÍA (TMDB) */}
  {
    film ? (
      <section class="border-b border-ink">
        <div class="frame">
          <div class="grid grid-cols-1 md:grid-cols-12">
            <div class="flex flex-col justify-between gap-6 border-ink py-8 md:col-span-5 md:border-r md:py-12 md:pr-10">
              <span class="label">{t('home.filmOfDay')}</span>
              <h1 class="text-display-mobile md:text-display-lg">
                <a href={localizePath(lang, `film/${film.tmdbId}`)} class="text-ink no-underline hover:text-muted">
                  {film.title}
                </a>
              </h1>
              <p class="max-w-2xl text-body-lg text-charcoal">{overview}</p>
              <div class="flex flex-wrap items-center gap-4">
                <a href={localizePath(lang, `film/${film.tmdbId}`)} class="btn btn-primary no-underline">
                  {t('home.viewFilm')}
                </a>
                <span class="font-mono text-meta-data text-muted">
                  {[film.year, film.voteAverage ? `★ ${film.voteAverage.toFixed(1)}` : null].filter(Boolean).join(' · ')}
                </span>
              </div>
            </div>

            <div class="md:col-span-7">
              <a
                href={localizePath(lang, `film/${film.tmdbId}`)}
                class="block h-full border-t border-ink md:border-l md:border-t-0"
              >
                {film.backdrop ? (
                  <img
                    src={film.backdrop}
                    alt={film.title}
                    width="1280"
                    height="720"
                    decoding="async"
                    class="h-56 w-full object-cover sm:h-72 md:h-full md:min-h-[24rem]"
                  />
                ) : (
                  <div class="film-grain h-56 w-full sm:h-72 md:h-full md:min-h-[24rem]" />
                )}
              </a>
            </div>
          </div>
        </div>
      </section>
    ) : (
      <section class="frame border-b border-ink py-16">
        <span class="label">{t('site.tagline')}</span>
        <h1 class="mt-4 text-display-mobile md:text-display-lg">{t('site.title')}</h1>
      </section>
    )
  }

  {/* BUSCADOR TMDB */}
  <section class="frame py-12">
    <TmdbSearch lang={lang} />
  </section>

  {/* ÚLTIMOS NÚMEROS (hemeroteca) */}
  <section class="frame py-12">
    <div class="mb-6 flex items-end justify-between border-b border-ink pb-3">
      <h2 class="text-headline-lg text-ink">{t('home.latestIssues')}</h2>
      <a href={localizePath(lang, 'archive')} class="label no-underline hover:text-ink">{t('home.viewArchive')} →</a>
    </div>

    <div class="grid grid-cols-2 gap-px border border-ink bg-ink sm:grid-cols-3 lg:grid-cols-4">
      {latestIssues.map((item) => <IssueCard item={item} lang={lang} />)}
    </div>
  </section>

  {/* CINE ABIERTO (dominio público) */}
  <section class="frame py-12">
    <div class="mb-6 flex items-end justify-between border-b border-ink pb-3">
      <h2 class="text-headline-lg text-ink">{t('nav.cinema')}</h2>
      <a href={localizePath(lang, 'cinema')} class="label no-underline hover:text-ink">{t('home.seeAll')} →</a>
    </div>
    <div class="grid grid-cols-1 gap-px border border-ink bg-ink sm:grid-cols-2 lg:grid-cols-4">
      {
        cinemaPicks.map((f) => (
          <a href={localizePath(lang, `cinema/${f.id}`)} class="group flex flex-col bg-surface no-underline hover:bg-film-white">
            <div class="aspect-video overflow-hidden border-b border-ink bg-charcoal">
              <img src={pdThumbUrl(f.id)} alt={f.title} loading="lazy" decoding="async" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
            </div>
            <div class="p-3">
              <h3 class="font-display text-headline-md leading-tight text-ink transition-colors group-hover:text-muted">{f.title}</h3>
              <p class="mt-1 font-mono text-meta-data text-muted">{f.director} · {f.year}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  {/* DOSIERES */}
  <section class="frame py-12">
    <div class="mb-6 flex items-end justify-between border-b border-ink pb-3">
      <h2 class="text-headline-lg text-ink">{t('nav.collections')}</h2>
      <a href={localizePath(lang, 'collections')} class="label no-underline hover:text-ink">{t('home.seeAll')} →</a>
    </div>
    <div class="grid grid-cols-1 gap-px border border-ink bg-ink sm:grid-cols-3">
      {
        collectionPicks.map((c) => (
          <a href={localizePath(lang, `collections/${c.slug}`)} class="group flex flex-col bg-surface p-5 no-underline transition-colors hover:bg-film-white">
            <span class="label">{c.tmdbIds.length} {t('collections.films')}</span>
            <h3 class="mt-2 font-display text-headline-md leading-tight text-ink transition-colors group-hover:text-muted">{collectionTitle(c, lang)}</h3>
            <p class="mt-2 text-body-md text-charcoal">{collectionBlurb(c, lang)}</p>
          </a>
        ))
      }
    </div>
  </section>

  {/* FIGURAS */}
  <section class="frame py-12">
    <div class="mb-6 flex items-end justify-between border-b border-ink pb-3">
      <h2 class="text-headline-lg text-ink">{t('nav.figures')}</h2>
      <a href={localizePath(lang, 'figures')} class="label no-underline hover:text-ink">{t('home.seeAll')} →</a>
    </div>
    <div class="grid grid-cols-3 gap-px border border-ink bg-ink sm:grid-cols-6">
      {
        figurePicks.map((f) => (
          <a href={localizePath(lang, `person/${f.id}`)} class="group flex flex-col bg-surface no-underline hover:bg-film-white">
            <div class="aspect-[2/3] w-full border-b border-ink bg-charcoal">
              {profileUrl(f.profile_path, 'w185') ? (
                <img src={profileUrl(f.profile_path, 'w185')} alt={f.name} loading="lazy" decoding="async" class="h-full w-full object-cover" />
              ) : (
                <div class="film-grain h-full w-full" />
              )}
            </div>
            <div class="p-2">
              <h3 class="font-display text-body-md leading-tight text-ink transition-colors group-hover:text-muted">{f.name}</h3>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  {/* REVISTAS ACTUALES · ACCESO ABIERTO */}
  <section class="frame py-12">
    <div class="mb-6 flex items-end justify-between border-b border-ink pb-3">
      <h2 class="text-headline-lg text-ink">{t('archive.current')}</h2>
      <a href={localizePath(lang, 'archive')} class="label no-underline hover:text-ink">{t('home.viewArchive')} →</a>
    </div>
    <p class="mb-8 max-w-2xl text-body-md text-charcoal">{t('archive.currentIntro')}</p>

    <div class="grid grid-cols-1 gap-px border border-ink bg-ink sm:grid-cols-2 lg:grid-cols-3">
      {journals.map((j) => <JournalCard item={j} lang={lang} />)}
    </div>
  </section>

  {/* BIBLIOTECA (textos de dominio público) */}
  <section class="frame py-12">
    <div class="mb-6 flex items-end justify-between border-b border-ink pb-3">
      <h2 class="text-headline-lg text-ink">{t('nav.library')}</h2>
      <a href={localizePath(lang, 'library')} class="label no-underline hover:text-ink">{t('home.seeAll')} →</a>
    </div>
    <div class="grid grid-cols-2 gap-px border border-ink bg-ink sm:grid-cols-4">
      {
        bookPicks.map((b) => (
          <a href={localizePath(lang, `library/${b.id}`)} class="group flex flex-col bg-surface no-underline hover:bg-film-white">
            <div class="aspect-[3/4] overflow-hidden border-b border-ink bg-charcoal">
              <img src={bookCoverUrl(b.id)} alt={b.title} loading="lazy" decoding="async" class="h-full w-full object-cover object-top" />
            </div>
            <div class="p-3">
              <h3 class="font-display text-headline-md leading-tight text-ink transition-colors group-hover:text-muted">{b.title}</h3>
              <p class="mt-1 font-mono text-meta-data text-muted">{b.author} · {b.year}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  {/* MANIFIESTO (antes en el navbar) */}
  <section class="frame border-t border-ink py-12">
    <header class="border-b border-ink pb-6">
      <span class="label">{t('about.title')}</span>
      <p class="mt-4 max-w-3xl font-display text-headline-md text-ink">{manifestoCopy.lead}</p>
    </header>

    <div class="grid grid-cols-1 gap-10 pt-8 md:grid-cols-12">
      <div class="prose-archive md:col-span-7 md:border-r md:border-ink md:pr-10">
        {manifestoCopy.body.map((p) => <p>{p}</p>)}
        <a href={localizePath(lang, 'about')} class="label mt-2 inline-block no-underline hover:text-ink">
          {t('home.readManifesto')} →
        </a>
      </div>

      <dl class="md:col-span-5">
        {
          manifestoCopy.principles.map(([term, desc], i) => (
            <div class:list={['py-4', i < manifestoCopy.principles.length - 1 && 'border-b border-outline-variant']}>
              <dt class="font-display text-headline-md text-ink">{term}</dt>
              <dd class="mt-1 text-body-md text-charcoal">{desc}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>
</BaseLayout>
