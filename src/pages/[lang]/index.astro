---
export const prerender = false; // la película del día se obtiene en cada visita (cacheada por día)
import BaseLayout from '../../layouts/BaseLayout.astro';
import IssueCard from '../../components/IssueCard.astro';
import { periodicals } from '../../lib/periodicals';
import { getFilmOfDay } from '../../lib/featured';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';

const lang = (Astro.params.lang === 'en' ? 'en' : 'es') as Lang;
const t = useTranslations(lang);

const latestIssues = periodicals
  .slice()
  .sort((a, b) => b.year - a.year || a.title.localeCompare(b.title))
  .slice(0, 4);

const film = await getFilmOfDay(lang);
const overview = film?.overview && film.overview.length > 320 ? film.overview.slice(0, 317) + '…' : film?.overview;
---

<BaseLayout altPath={localizePath(lang === 'es' ? 'en' : 'es')}>
  {/* HERO — PELÍCULA DEL DÍA (TMDB) */}
  {
    film ? (
      <section class="border-b border-ink">
        <div class="frame">
          <div class="grid grid-cols-1 md:grid-cols-12">
            <div class="flex flex-col justify-between gap-6 border-ink py-8 md:col-span-5 md:border-r md:py-12 md:pr-10">
              <span class="label">{t('home.filmOfDay')}</span>
              <h1 class="text-display-mobile md:text-display-lg">
                <a href={localizePath(lang, `film/${film.tmdbId}`)} class="text-ink no-underline hover:text-muted">
                  {film.title}
                </a>
              </h1>
              <p class="max-w-2xl text-body-lg text-charcoal">{overview}</p>
              <div class="flex flex-wrap items-center gap-4">
                <a href={localizePath(lang, `film/${film.tmdbId}`)} class="btn btn-primary no-underline">
                  {t('home.viewFilm')}
                </a>
                <span class="font-mono text-meta-data text-muted">
                  {[film.year, film.voteAverage ? `★ ${film.voteAverage.toFixed(1)}` : null].filter(Boolean).join(' · ')}
                </span>
              </div>
            </div>

            <div class="md:col-span-7">
              <a
                href={localizePath(lang, `film/${film.tmdbId}`)}
                class="block h-full border-t border-ink md:border-l md:border-t-0"
              >
                {film.backdrop ? (
                  <img
                    src={film.backdrop}
                    alt={film.title}
                    width="1280"
                    height="720"
                    decoding="async"
                    class="h-56 w-full object-cover sm:h-72 md:h-full md:min-h-[24rem]"
                  />
                ) : (
                  <div class="film-grain h-56 w-full sm:h-72 md:h-full md:min-h-[24rem]" />
                )}
              </a>
            </div>
          </div>
        </div>
      </section>
    ) : (
      <section class="frame border-b border-ink py-16">
        <span class="label">{t('site.tagline')}</span>
        <h1 class="mt-4 text-display-mobile md:text-display-lg">{t('site.title')}</h1>
      </section>
    )
  }

  {/* ÚLTIMOS NÚMEROS (hemeroteca) */}
  <section class="frame py-12">
    <div class="mb-6 flex items-end justify-between border-b border-ink pb-3">
      <h2 class="text-headline-lg text-ink">{t('home.latestIssues')}</h2>
      <a href={localizePath(lang, 'archive')} class="label no-underline hover:text-ink">{t('home.viewArchive')} →</a>
    </div>

    <div class="grid grid-cols-2 gap-px border-l border-r border-ink bg-ink sm:grid-cols-3 lg:grid-cols-4">
      {latestIssues.map((item) => <IssueCard item={item} lang={lang} />)}
    </div>
  </section>
</BaseLayout>
