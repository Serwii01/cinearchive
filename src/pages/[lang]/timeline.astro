---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { timeline, movementName, movementDesc } from '../../lib/reference';
import { getFilmsBrief } from '../../lib/films';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';

const lang = (Astro.params.lang === 'en' ? 'en' : 'es') as Lang;
const t = useTranslations(lang);

// Resolver títulos de las películas clave (cacheado en films_cache).
const allIds = [...new Set(timeline.flatMap((m) => m.keyFilms))];
const briefs = await getFilmsBrief(allIds, lang);
---

<BaseLayout
  title={t('timeline.title')}
  description={t('timeline.intro')}
  altPath={localizePath(lang === 'es' ? 'en' : 'es', 'timeline')}
>
  <section class="frame py-12">
    <a href={localizePath(lang, 'archive')} class="label no-underline hover:text-ink">← {t('nav.archive')}</a>
    <header class="mt-6 border-b border-ink pb-6">
      <span class="label">{t('timeline.title')}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{t('timeline.title')}</h1>
      <p class="mt-4 max-w-2xl text-body-lg text-charcoal">{t('timeline.intro')}</p>
    </header>

    <ol class="mt-10 border-l-2 border-ink">
      {
        timeline.map((m) => (
          <li class="relative pb-10 pl-6 last:pb-0">
            <span class="absolute -left-[7px] top-1.5 h-3 w-3 border-2 border-ink bg-ochre"></span>
            <span class="label text-muted">{m.period}</span>
            <h2 class="mt-1 font-display text-headline-lg text-ink">{movementName(m, lang)}</h2>
            <p class="mt-2 max-w-2xl text-body-md text-charcoal">{movementDesc(m, lang)}</p>
            {m.keyFilms.length > 0 && (
              <div class="mt-3">
                <span class="label">{t('timeline.keyFilms')}:</span>
                <div class="mt-2 flex flex-wrap gap-2">
                  {m.keyFilms.map((id) => {
                    const f = briefs.get(id);
                    return f ? (
                      <a href={localizePath(lang, `film/${id}`)} class="label border border-ink px-3 py-1 no-underline transition-colors hover:bg-ink hover:text-white">
                        {f.title}{f.year && ` (${f.year})`}
                      </a>
                    ) : null;
                  })}
                </div>
              </div>
            )}
          </li>
        ))
      }
    </ol>
  </section>
</BaseLayout>
