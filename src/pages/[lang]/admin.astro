---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { db } from '../../db/client';
import { user, userFilms, filmsCache, watchCache, extraFilms } from '../../db/schema';
import { count, desc } from 'drizzle-orm';
import { getWatchmodeStatus } from '../../lib/watchmode';

// El middleware garantiza que solo entran cuentas de ADMIN_EMAILS.
const lang = (Astro.params.lang === 'en' ? 'en' : 'es') as Lang;
const t = useTranslations(lang);
const me = Astro.locals.user!;

const [wm, users, filmCounts, fc, wc, uf, extras] = await Promise.all([
  getWatchmodeStatus(),
  db.select().from(user).orderBy(desc(user.createdAt)).limit(500),
  db.select({ userId: userFilms.userId, c: count() }).from(userFilms).groupBy(userFilms.userId),
  db.select({ c: count() }).from(filmsCache),
  db.select({ c: count() }).from(watchCache),
  db.select({ c: count() }).from(userFilms),
  db.select().from(extraFilms).orderBy(desc(extraFilms.addedAt)),
]);

const filmCountMap = new Map(filmCounts.map((r) => [r.userId, r.c]));
const fmtDate = (d: Date) => new Date(d).toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-GB');

const apiCards = [
  {
    name: 'Watchmode',
    value: wm ? `${wm.quota - wm.quotaUsed} / ${wm.quota}` : t('admin.noKey'),
    note: wm ? t('admin.remaining') : '',
    warn: wm ? wm.quota - wm.quotaUsed < wm.quota * 0.1 : false,
  },
  { name: 'OMDb', value: '—', note: t('admin.noCounter'), warn: false },
  { name: 'TMDB', value: '∞', note: t('admin.unlimited'), warn: false },
];
const dataCards = [
  { label: t('admin.usersCount'), value: users.length },
  { label: t('admin.cachedFilms'), value: fc[0]?.c ?? 0 },
  { label: t('admin.watchRegions'), value: wc[0]?.c ?? 0 },
  { label: t('admin.listEntries'), value: uf[0]?.c ?? 0 },
  { label: t('admin.extraFilmsCount'), value: extras.length },
];
---

<BaseLayout title={t('admin.title')}>
  <section class="frame py-12" data-confirm={t('admin.confirmDelete')} data-adderr={t('admin.addError')}>
    <a href={localizePath(lang, 'account')} class="label no-underline hover:text-ink">← {t('nav.backToAccount')}</a>
    <header class="mt-6 border-b border-ink pb-6">
      <span class="label">{t('admin.title')}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{t('admin.title')}</h1>
    </header>

    {/* CONSUMO DE APIs */}
    <h2 class="mt-10 border-b border-ink pb-2 text-headline-lg text-ink">{t('admin.apiUsage')}</h2>
    <div class="mt-4 grid grid-cols-1 gap-px border border-ink bg-ink sm:grid-cols-3">
      {apiCards.map((c) => (
        <div class="bg-surface p-4">
          <span class="label">{c.name}</span>
          <p class:list={['mt-1 font-display text-display-mobile', c.warn ? 'text-error' : 'text-ink']}>{c.value}</p>
          <p class="font-mono text-meta-data text-muted">{c.note}</p>
        </div>
      ))}
    </div>

    {/* CACHÉS Y DATOS */}
    <h2 class="mt-10 border-b border-ink pb-2 text-headline-lg text-ink">{t('admin.dataTitle')}</h2>
    <div class="mt-4 grid grid-cols-2 gap-px border border-ink bg-ink sm:grid-cols-5">
      {dataCards.map((c) => (
        <div class="bg-surface p-4">
          <span class="label">{c.label}</span>
          <p class="mt-1 font-display text-display-mobile text-ink">{c.value}</p>
        </div>
      ))}
    </div>

    {/* AÑADIR PELÍCULA */}
    <h2 class="mt-10 border-b border-ink pb-2 text-headline-lg text-ink">{t('admin.addFilm')}</h2>
    <form id="add-film-form" class="mt-4 flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1">
        <span class="label">{t('admin.tmdbId')}</span>
        <input id="tmdb-id" type="number" min="1" required class="w-48 border border-ink bg-white px-3 py-2 font-mono text-meta-data text-ink focus:bg-film-white focus:outline-none" />
      </label>
      <button type="submit" class="btn btn-primary">{t('admin.add')}</button>
      <span id="add-msg" class="font-mono text-meta-data text-muted"></span>
    </form>
    <p class="mt-2 font-mono text-meta-data text-muted">{t('admin.tmdbHint')}</p>

    {extras.length > 0 && (
      <div class="mt-6 overflow-x-auto border border-ink">
        <table class="w-full border-collapse text-left">
          <thead>
            <tr class="border-b border-ink bg-ink text-background">
              <th class="label px-3 py-2 font-medium text-background">{t('films.colTitle')}</th>
              <th class="label hidden px-3 py-2 font-medium text-background sm:table-cell">{t('films.colDirector')}</th>
              <th class="label px-3 py-2 font-medium text-background">{t('films.colYear')}</th>
              <th class="label px-3 py-2 text-right font-medium text-background">TMDB</th>
              <th class="px-3 py-2"></th>
            </tr>
          </thead>
          <tbody>
            {extras.map((f) => (
              <tr class="border-b border-outline-variant last:border-b-0">
                <td class="px-3 py-2 font-display text-headline-md text-ink">{f.title}</td>
                <td class="hidden px-3 py-2 font-mono text-meta-data text-charcoal sm:table-cell">{f.director}</td>
                <td class="px-3 py-2 font-mono text-meta-data text-charcoal">{f.year}</td>
                <td class="px-3 py-2 text-right font-mono text-meta-data text-muted">{f.tmdbId}</td>
                <td class="px-3 py-2 text-right">
                  <button type="button" data-remove-film={f.tmdbId} class="label border border-ink px-2 py-1 transition-colors hover:bg-error hover:text-white">{t('admin.remove')}</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    {/* USUARIOS */}
    <h2 class="mt-12 border-b border-ink pb-2 text-headline-lg text-ink">{t('admin.users')} · {users.length}</h2>
    <div class="mt-4 overflow-x-auto border border-ink">
      <table class="w-full border-collapse text-left">
        <thead>
          <tr class="border-b border-ink bg-ink text-background">
            <th class="label px-3 py-2 font-medium text-background">{t('auth.name')}</th>
            <th class="label px-3 py-2 font-medium text-background">{t('auth.email')}</th>
            <th class="label hidden px-3 py-2 text-right font-medium text-background sm:table-cell">{t('admin.createdAt')}</th>
            <th class="label px-3 py-2 text-right font-medium text-background">{t('nav.films')}</th>
            <th class="px-3 py-2"></th>
          </tr>
        </thead>
        <tbody>
          {users.map((u) => (
            <tr class="border-b border-outline-variant last:border-b-0 align-middle">
              <td class="px-3 py-2 font-display text-headline-md text-ink">{u.name}</td>
              <td class="px-3 py-2 font-mono text-meta-data text-charcoal">{u.email}</td>
              <td class="hidden px-3 py-2 text-right font-mono text-meta-data text-muted sm:table-cell">{fmtDate(u.createdAt)}</td>
              <td class="px-3 py-2 text-right font-mono text-meta-data text-charcoal">{filmCountMap.get(u.id) ?? 0}</td>
              <td class="px-3 py-2 text-right">
                {u.id === me.id ? (
                  <span class="label text-muted">{t('admin.you')}</span>
                ) : (
                  <button type="button" data-del-user={u.id} class="label border border-ink px-2 py-1 transition-colors hover:bg-error hover:text-white">{t('admin.delete')}</button>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>

<script>
  const root = document.querySelector('[data-confirm]') as HTMLElement;
  const confirmMsg = root?.dataset.confirm || 'Delete?';
  const addErr = root?.dataset.adderr || 'Error';

  // Añadir película
  const form = document.getElementById('add-film-form') as HTMLFormElement | null;
  const msg = document.getElementById('add-msg');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('tmdb-id') as HTMLInputElement;
    const tmdbId = Number(input.value);
    if (!tmdbId) return;
    if (msg) msg.textContent = '…';
    try {
      const res = await fetch('/api/admin/films', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ tmdbId }),
      });
      if (res.ok) location.reload();
      else if (msg) msg.textContent = addErr;
    } catch {
      if (msg) msg.textContent = addErr;
    }
  });

  // Quitar película añadida
  document.querySelectorAll<HTMLButtonElement>('[data-remove-film]').forEach((b) =>
    b.addEventListener('click', async () => {
      const tmdbId = Number(b.dataset.removeFilm);
      const res = await fetch('/api/admin/films', {
        method: 'DELETE',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ tmdbId }),
      });
      if (res.ok) location.reload();
    }),
  );

  // Eliminar usuario
  document.querySelectorAll<HTMLButtonElement>('[data-del-user]').forEach((b) =>
    b.addEventListener('click', async () => {
      if (!confirm(confirmMsg)) return;
      const userId = b.dataset.delUser;
      const res = await fetch('/api/admin/users', {
        method: 'DELETE',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ userId }),
      });
      if (res.ok) location.reload();
    }),
  );
</script>
