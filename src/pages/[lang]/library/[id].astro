---
export const prerender = true;
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { books, bookEmbedUrl, bookIaUrl, type Book } from '../../../lib/library';
import { languages, localizedField, useTranslations, localizePath, type Lang } from '../../../i18n/ui';

export function getStaticPaths() {
  const paths: { params: { lang: string; id: string }; props: { item: Book } }[] = [];
  for (const lang of Object.keys(languages)) {
    for (const item of books) {
      paths.push({ params: { lang, id: item.id }, props: { item } });
    }
  }
  return paths;
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const { item } = Astro.props as { item: Book };

const blurb = localizedField(item, 'blurb', lang);
---

<BaseLayout title={item.title} description={blurb}>
  <article class="frame py-12">
    <a href={localizePath(lang, 'library')} class="label no-underline hover:text-ink">← {t('library.backToLibrary')}</a>

    <header class="mt-6 border-b border-ink pb-6">
      <span class="label">{t('cinema.publicDomain')} · {item.year}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{item.title}</h1>
      <p class="mt-3 font-mono text-meta-data uppercase tracking-[0.08em] text-muted">{t('library.author')}: {item.author}</p>
      <p class="mt-5 max-w-2xl text-body-lg text-charcoal">{blurb}</p>
      <a href={bookIaUrl(item.id)} target="_blank" rel="noopener noreferrer" class="btn btn-secondary mt-6 no-underline">
        {t('library.atIA')} ↗
      </a>
    </header>

    {/* Lector incrustado de Internet Archive (BookReader) */}
    <div class="mt-8 border border-ink bg-charcoal">
      <div class="border-b border-ink bg-ink px-3 py-2">
        <span class="label text-background">{t('library.reader')}</span>
      </div>
      <iframe
        src={bookEmbedUrl(item.id)}
        title={item.title}
        loading="lazy"
        allowfullscreen
        class="h-[78vh] min-h-[28rem] w-full"
        style="border:0"
      ></iframe>
    </div>

    <p class="mt-6 font-mono text-meta-data text-muted">{t('library.readerNote')}</p>
  </article>
</BaseLayout>
