---
export const prerender = true;
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { books, bookCoverUrl } from '../../../lib/library';
import { useTranslations, localizePath, type Lang } from '../../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const items = books.slice().sort((a, b) => a.year - b.year || a.title.localeCompare(b.title));
---

<BaseLayout
  title={t('library.title')}
  description={t('library.intro')}
  altPath={localizePath(lang === 'es' ? 'en' : 'es', 'library')}
>
  <section class="frame py-12">
    <a href={localizePath(lang, 'archive')} class="label no-underline hover:text-ink">← {t('nav.archive')}</a>
    <header class="mt-6 border-b border-ink pb-6">
      <span class="label">{t('library.title')} · {items.length} {t('library.count')}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{t('library.title')}</h1>
      <p class="mt-4 max-w-2xl text-body-lg text-charcoal">{t('library.intro')}</p>
    </header>

    <div class="mt-10 grid grid-cols-2 gap-px border-l border-r border-ink bg-ink sm:grid-cols-3 lg:grid-cols-4">
      {
        items.map((b) => (
          <article class="group flex h-full flex-col border-t border-ink bg-surface">
            <a href={localizePath(lang, `library/${b.id}`)} class="flex h-full flex-col no-underline">
              <div class="flex items-center justify-between border-b border-ink px-3 py-2">
                <span class="label">{t('cinema.publicDomain')}</span>
                <span class="font-mono text-meta-data text-muted">{b.year}</span>
              </div>
              <div class="aspect-[3/4] overflow-hidden border-b border-ink bg-charcoal">
                <img
                  src={bookCoverUrl(b.id)}
                  alt={b.title}
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover object-top"
                />
              </div>
              <div class="flex flex-1 flex-col p-3">
                <h2 class="font-display text-headline-md leading-tight text-ink transition-colors group-hover:text-muted">{b.title}</h2>
                <p class="mt-1 font-mono text-meta-data text-muted">{b.author}</p>
              </div>
            </a>
          </article>
        ))
      }
    </div>

    <p class="mt-10 border-t border-ink pt-4 font-mono text-meta-data text-muted">{t('archive.credit')}</p>
  </section>
</BaseLayout>
