---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAtlas, project } from '../../lib/atlas';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const W = 360;
const H = 180;
const entries = getAtlas();
const total = entries.reduce((n, e) => n + e.count, 0);
const markers = entries.map((e) => {
  const { x, y } = project(e.lon, e.lat, W, H);
  return { ...e, x, y, r: 2.5 + Math.sqrt(e.count) * 1.3, name: lang === 'es' ? e.es : e.en };
});
const lons = [-150, -120, -90, -60, -30, 0, 30, 60, 90, 120, 150];
const lats = [-60, -30, 0, 30, 60];
const discover = (iso: string) => `${localizePath(lang, 'discover')}?country=${iso}`;
---

<BaseLayout
  title={t('atlas.title')}
  description={t('atlas.intro')}
  altPath={localizePath(lang === 'es' ? 'en' : 'es', 'atlas')}
>
  <section class="frame py-12">
    <a href={localizePath(lang, 'films')} class="label no-underline hover:text-ink">← {t('nav.films')}</a>
    <header class="mt-6 border-b border-ink pb-6">
      <span class="label">{t('atlas.title')} · {entries.length} {t('atlas.countries')}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{t('atlas.title')}</h1>
      <p class="mt-4 max-w-2xl text-body-lg text-charcoal">{t('atlas.intro')}</p>
    </header>

    {/* Mapa SVG (proyección equirectangular, sin librerías ni teselas externas) */}
    <div class="mt-8 border border-ink bg-charcoal p-3">
      <svg viewBox={`0 0 ${W} ${H}`} class="h-auto w-full" role="img" aria-label={t('atlas.title')}>
        {lons.map((lon) => {
          const x = ((lon + 180) / 360) * W;
          return <line x1={x} y1="0" x2={x} y2={H} style="stroke:var(--c-outline-variant);stroke-width:0.2;opacity:0.5" />;
        })}
        {lats.map((lat) => {
          const y = ((90 - lat) / 180) * H;
          return <line x1="0" y1={y} x2={W} y2={y} style={`stroke:var(--c-outline-variant);stroke-width:${lat === 0 ? 0.5 : 0.2};opacity:${lat === 0 ? 0.8 : 0.5}`} />;
        })}
        {markers.map((m) => (
          <a href={discover(m.iso)}>
            <circle cx={m.x} cy={m.y} r={m.r} style="fill:var(--c-ochre);stroke:var(--c-ink);stroke-width:0.4">
              <title>{m.name} · {m.count}</title>
            </circle>
            <text x={m.x} y={m.y - m.r - 1.5} text-anchor="middle" style="fill:var(--c-background);font-size:4px;font-family:monospace">{m.iso}</text>
          </a>
        ))}
      </svg>
    </div>

    {/* Índice por país */}
    <ul class="mt-8 grid grid-cols-1 gap-px border border-ink bg-ink sm:grid-cols-2 lg:grid-cols-3">
      {
        markers.map((m) => (
          <a href={discover(m.iso)} class="group flex items-center justify-between gap-3 bg-surface px-4 py-3 no-underline transition-colors hover:bg-film-white">
            <span class="font-display text-headline-md leading-none text-ink transition-colors group-hover:text-muted">{m.name}</span>
            <span class="shrink-0 font-mono text-meta-data text-muted">{m.count} {t('atlas.films')}</span>
          </a>
        ))
      }
    </ul>
    <p class="mt-6 font-mono text-meta-data text-muted">{total} {t('atlas.films')} · {entries.length} {t('atlas.countries')}</p>
  </section>
</BaseLayout>
