---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAtlas, project } from '../../lib/atlas';
import worldmap from '../../data/worldmap.json';
import { languages, useTranslations, localizePath, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const W = 360;
const H = 180;
const entries = getAtlas();
const total = entries.reduce((n, e) => n + e.count, 0);
const maxCount = entries[0]?.count ?? 1;
const markers = entries.map((e) => {
  const { x, y } = project(e.lon, e.lat, W, H);
  return { ...e, x, y, r: 3 + Math.sqrt(e.count) * 1.6, name: e[lang] };
});
const discover = (iso: string) => `${localizePath(lang, 'discover')}?country=${iso}`;
---

<BaseLayout
  title={t('atlas.title')}
  description={t('atlas.intro')}
>
  <section class="frame py-12">
    <a href={localizePath(lang, 'films')} class="label no-underline hover:text-ink">← {t('nav.films')}</a>
    <header class="mt-6 border-b border-ink pb-6">
      <span class="label">{t('atlas.title')} · {entries.length} {t('atlas.countries')} · {total} {t('atlas.films')}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{t('atlas.title')}</h1>
      <p class="mt-4 max-w-2xl text-body-lg text-charcoal">{t('atlas.intro')}</p>
    </header>

    {/* Ranking proporcional — la vista legible */}
    <ul class="mt-10 flex flex-col gap-2">
      {
        markers.map((m) => (
          <li>
            <a
              href={discover(m.iso)}
              class="group grid grid-cols-[6rem_1fr_2.5rem] items-center gap-3 no-underline sm:grid-cols-[10rem_1fr_3rem]"
            >
              <span class="truncate font-mono text-meta-data text-charcoal transition-colors group-hover:text-ink">{m.name}</span>
              <span class="relative h-5 bg-surface-dim">
                <span class="absolute inset-y-0 left-0 bg-ink transition-colors group-hover:bg-ochre" style={`width:${Math.max(3, Math.round((m.count / maxCount) * 100))}%`}></span>
              </span>
              <span class="text-right font-mono text-meta-data text-muted">{m.count}</span>
            </a>
          </li>
        ))
      }
    </ul>

    {/* Mapa mundial (contornos reales, sin librerías ni teselas externas) */}
    <div class="mt-12 border border-ink bg-surface p-3">
      <svg viewBox={`0 0 ${W} ${H}`} class="h-auto w-full" role="img" aria-label={t('atlas.title')}>
        <path d={worldmap.d} style="fill:var(--c-ink);fill-opacity:0.12;stroke:var(--c-ink);stroke-opacity:0.28;stroke-width:0.15;stroke-linejoin:round" />
        {markers.map((m) => (
          <a href={discover(m.iso)}>
            <circle cx={m.x} cy={m.y} r={m.r * 1.9} style="fill:var(--c-ochre);opacity:0.2" />
            <circle cx={m.x} cy={m.y} r={m.r} style="fill:var(--c-ochre);stroke:var(--c-ink);stroke-width:0.5">
              <title>{m.name} · {m.count} {t('atlas.films')}</title>
            </circle>
          </a>
        ))}
      </svg>
    </div>
    <p class="mt-3 font-mono text-meta-data text-muted">{t('atlas.explore')} →</p>
  </section>
</BaseLayout>
