---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { collectionBySlug, collectionTitle, collectionBlurb } from '../../../lib/collections';
import { getFilmsBrief } from '../../../lib/films';
import { normalizeLang, useTranslations, localizePath, type Lang } from '../../../i18n/ui';
import { filmSlug } from '../../../lib/slug';

const lang = normalizeLang(Astro.params.lang);
const t = useTranslations(lang);

const collection = collectionBySlug(Astro.params.slug ?? '');
if (!collection) return Astro.redirect(localizePath(lang, 'collections'));

const briefs = await getFilmsBrief(collection.tmdbIds, lang);
// Mantener el orden curado y descartar los que no resuelvan.
const films = collection.tmdbIds.map((id) => briefs.get(id)).filter((f) => f != null);
---

<BaseLayout title={collectionTitle(collection, lang)} description={collectionBlurb(collection, lang)}>
  <section class="frame py-12">
    <a href={localizePath(lang, 'collections')} class="label no-underline hover:text-ink">← {t('collections.backToCollections')}</a>
    <header class="mt-6 border-b border-ink pb-6">
      <span class="label">{t('collections.title')} · {films.length} {t('collections.films')}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{collectionTitle(collection, lang)}</h1>
      <p class="mt-4 max-w-2xl text-body-lg text-charcoal">{collectionBlurb(collection, lang)}</p>
    </header>

    <div class="mt-10 grid grid-cols-2 gap-px border border-ink bg-ink sm:grid-cols-3 lg:grid-cols-6">
      {
        films.map((f) => (
          <a href={localizePath(lang, `film/${filmSlug(f!.tmdbId, f!.title)}`)} class="group flex flex-col bg-surface no-underline hover:bg-film-white">
            <div class="aspect-[2/3] w-full border-b border-ink bg-charcoal">
              {f!.poster ? (
                <img src={f!.poster} alt={f!.title} loading="lazy" decoding="async" class="h-full w-full object-cover" />
              ) : (
                <div class="film-grain h-full w-full" />
              )}
            </div>
            <div class="flex flex-1 flex-col p-2">
              <p class="font-display text-body-lg leading-tight text-ink">{f!.title}</p>
              <p class="font-mono text-meta-data text-muted">{[f!.director, f!.year].filter(Boolean).join(' · ')}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
