---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { enabledSocialProviders } from '../../lib/auth';

const lang = (Astro.params.lang === 'en' ? 'en' : 'es') as Lang;
const t = useTranslations(lang);

// Si ya hay sesión, fuera de aquí.
if (Astro.locals.user) return Astro.redirect(localizePath(lang, 'account'));

const next = Astro.url.searchParams.get('next') || localizePath(lang);
const hasGoogle = enabledSocialProviders.includes('google');
const hasGithub = enabledSocialProviders.includes('github');
---

<BaseLayout title={t('auth.loginTitle')}>
  <section class="frame py-12">
    <div class="mx-auto max-w-md border border-ink bg-surface">
      <h1 class="border-b border-ink px-6 py-4 font-display text-headline-lg text-ink">{t('auth.loginTitle')}</h1>

      <form id="login-form" class="flex flex-col gap-4 p-6" novalidate data-errmsg={t('auth.error')}>
        <label class="block">
          <span class="label mb-1 block">{t('auth.email')}</span>
          <input name="email" type="email" required autocomplete="email" class="w-full border border-ink bg-white px-3 py-2 font-body text-body-md focus:bg-film-white focus:outline-none" />
        </label>
        <label class="block">
          <span class="label mb-1 block">{t('auth.password')}</span>
          <input name="password" type="password" required autocomplete="current-password" minlength="8" class="w-full border border-ink bg-white px-3 py-2 font-body text-body-md focus:bg-film-white focus:outline-none" />
        </label>
        <p data-error class="hidden font-mono text-meta-data text-error"></p>
        <button type="submit" class="btn btn-primary justify-center">{t('auth.signIn')}</button>
      </form>

      {(hasGoogle || hasGithub) && (
        <div class="border-t border-ink p-6">
          <p class="label mb-3 text-center">{t('auth.or')}</p>
          <div class="flex flex-col gap-3">
            {hasGoogle && <button type="button" data-social="google" class="btn btn-secondary justify-center">{t('auth.withGoogle')}</button>}
            {hasGithub && <button type="button" data-social="github" class="btn btn-secondary justify-center">{t('auth.withGithub')}</button>}
          </div>
        </div>
      )}

      <a href={localizePath(lang, 'register')} class="block border-t border-ink px-6 py-4 text-center font-mono text-meta-data text-muted no-underline hover:text-ink">
        {t('auth.noAccount')}
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  import { signIn } from '../../lib/auth-client';

  const form = document.getElementById('login-form') as HTMLFormElement;
  const errEl = form.querySelector('[data-error]') as HTMLElement;
  const params = new URLSearchParams(window.location.search);
  const next = params.get('next') || window.location.pathname.replace(/\/login$/, '');
  const errMsg = form.dataset.errmsg || 'Error';

  const showError = (msg: string) => {
    errEl.textContent = msg;
    errEl.classList.remove('hidden');
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errEl.classList.add('hidden');
    const fd = new FormData(form);
    const { error } = await signIn.email({
      email: String(fd.get('email')),
      password: String(fd.get('password')),
    });
    if (error) showError(error.message || errMsg);
    else window.location.href = next;
  });

  document.querySelectorAll<HTMLButtonElement>('[data-social]').forEach((b) =>
    b.addEventListener('click', () =>
      signIn.social({ provider: b.dataset.social as 'google' | 'github', callbackURL: next }),
    ),
  );
</script>
