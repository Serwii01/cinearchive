---
export const prerender = true;
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { pdFilms, pdEmbedUrl, pdIaUrl, type PdFilm } from '../../../lib/pdfilms';
import { useTranslations, localizePath, type Lang } from '../../../i18n/ui';

export function getStaticPaths() {
  const paths: { params: { lang: string; id: string }; props: { item: PdFilm } }[] = [];
  for (const lang of ['es', 'en']) {
    for (const item of pdFilms) {
      paths.push({ params: { lang, id: item.id }, props: { item } });
    }
  }
  return paths;
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const { item } = Astro.props as { item: PdFilm };

const blurb = lang === 'es' ? item.blurb_es : item.blurb_en;
const altPath = localizePath(lang === 'es' ? 'en' : 'es', `cinema/${item.id}`);
const meta = [item.director, item.country, item.year, `${item.runtime}′`].filter(Boolean).join(' · ');
---

<BaseLayout title={item.title} description={blurb} altPath={altPath}>
  <article class="frame py-12">
    <a href={localizePath(lang, 'cinema')} class="label no-underline hover:text-ink">← {t('cinema.backToCinema')}</a>

    <header class="mt-6 border-b border-ink pb-6">
      <span class="label">{t('cinema.publicDomain')} · {item.year}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{item.title}</h1>
      {item.original_title !== item.title && (
        <p class="mt-2 font-display text-headline-md italic text-muted">{item.original_title}</p>
      )}
      <p class="mt-3 font-mono text-meta-data uppercase tracking-[0.08em] text-muted">{meta}</p>
      <p class="mt-5 max-w-2xl text-body-lg text-charcoal">{blurb}</p>
      <a href={pdIaUrl(item.id)} target="_blank" rel="noopener noreferrer" class="btn btn-secondary mt-6 no-underline">
        {t('cinema.atIA')} ↗
      </a>
    </header>

    {/* Reproductor incrustado de Internet Archive */}
    <div class="mt-8 border border-ink bg-charcoal">
      <div class="border-b border-ink bg-ink px-3 py-2">
        <span class="label text-background">{t('cinema.watch')}</span>
      </div>
      <iframe
        src={pdEmbedUrl(item.id)}
        title={item.title}
        loading="lazy"
        allow="fullscreen"
        allowfullscreen
        class="aspect-video w-full"
        style="border:0"
      ></iframe>
    </div>

    <p class="mt-6 font-mono text-meta-data text-muted">{t('cinema.viewerNote')}</p>
  </article>
</BaseLayout>
