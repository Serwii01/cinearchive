---
export const prerender = true;
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { pdFilms, pdThumbUrl } from '../../../lib/pdfilms';
import { languages, localizedField, useTranslations, localizePath, type Lang } from '../../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const items = pdFilms.slice().sort((a, b) => a.year - b.year || a.title.localeCompare(b.title));
const decades = [...new Set(items.map((i) => Math.floor(i.year / 10) * 10))].sort((a, b) => a - b);
---

<BaseLayout
  title={t('cinema.title')}
  description={t('cinema.intro')}
>
  <section class="frame py-12">
    <a href={localizePath(lang, 'films')} class="label no-underline hover:text-ink">← {t('nav.films')}</a>
    <header class="mt-6 border-b border-ink pb-6">
      <span class="label">{t('cinema.title')} · {items.length} {t('cinema.count')}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{t('cinema.title')}</h1>
      <p class="mt-4 max-w-2xl text-body-lg text-charcoal">{t('cinema.intro')}</p>

      <div class="mt-6 flex flex-wrap gap-3">
        <label class="flex items-center gap-2">
          <span class="label">{t('archive.filterDecade')}</span>
          <select id="filter-decade" class="border border-ink bg-white px-2 py-1 font-mono text-meta-data text-ink focus:bg-film-white focus:outline-none">
            <option value="">{t('archive.all')}</option>
            {decades.map((d) => <option value={d}>{d}s</option>)}
          </select>
        </label>
      </div>
    </header>

    <div
      id="cinema-grid"
      class="mt-10 grid grid-cols-1 gap-px border border-ink bg-ink sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        items.map((f) => (
          <article data-decade={Math.floor(f.year / 10) * 10} class="group flex h-full flex-col bg-surface">
            <a href={localizePath(lang, `cinema/${f.id}`)} class="flex h-full flex-col no-underline">
              <div class="flex items-center justify-between border-b border-ink px-3 py-2">
                <span class="label">{t('cinema.publicDomain')}</span>
                <span class="font-mono text-meta-data text-muted">{f.year}</span>
              </div>
              <div class="aspect-video overflow-hidden border-b border-ink bg-charcoal">
                <img
                  src={pdThumbUrl(f.id)}
                  alt={f.title}
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
              </div>
              <div class="flex flex-1 flex-col p-3">
                <h2 class="font-display text-headline-md leading-tight text-ink transition-colors group-hover:text-muted">{f.title}</h2>
                <p class="mt-1 font-mono text-meta-data text-muted">{f.director} · {f.country} · {f.runtime}′</p>
                <p class="mt-2 text-body-md text-charcoal">{localizedField(f, 'blurb', lang)}</p>
              </div>
            </a>
          </article>
        ))
      }
    </div>
    <p id="cinema-empty" class="mt-10 hidden font-mono text-body-md text-muted">{t('archive.empty')}</p>

    <p class="mt-10 border-t border-ink pt-4 font-mono text-meta-data text-muted">{t('archive.credit')}</p>
  </section>
</BaseLayout>

<script>
  const decadeSel = document.getElementById('filter-decade') as HTMLSelectElement | null;
  const cells = Array.from(document.querySelectorAll<HTMLElement>('#cinema-grid > [data-decade]'));
  const empty = document.getElementById('cinema-empty');

  const apply = () => {
    const de = decadeSel?.value ?? '';
    let visible = 0;
    for (const cell of cells) {
      const ok = !de || cell.dataset.decade === de;
      cell.hidden = !ok;
      if (ok) visible++;
    }
    empty?.classList.toggle('hidden', visible !== 0);
  };

  decadeSel?.addEventListener('change', apply);
</script>
