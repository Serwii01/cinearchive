---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { awards, awardName, awardNote } from '../../lib/awards';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
---

<BaseLayout
  title={t('awards.title')}
  description={t('awards.intro')}
  altPath={localizePath(lang === 'es' ? 'en' : 'es', 'awards')}
>
  <section class="frame py-12">
    <a href={localizePath(lang, 'archive')} class="label no-underline hover:text-ink">← {t('nav.archive')}</a>
    <header class="mt-6 border-b border-ink pb-6">
      <span class="label">{t('awards.title')}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{t('awards.title')}</h1>
      <p class="mt-4 max-w-2xl text-body-lg text-charcoal">{t('awards.intro')}</p>
    </header>

    {
      awards.map((a) => (
        <section class="mt-12">
          <h2 class="border-b border-ink pb-2 text-headline-lg text-ink">{awardName(a, lang)}</h2>
          <p class="mt-2 font-mono text-meta-data text-muted">{awardNote(a, lang)}</p>
          <div class="mt-4 overflow-x-auto border border-ink">
            <table class="w-full border-collapse text-left">
              <thead>
                <tr class="border-b border-ink bg-ink text-background">
                  <th class="label px-3 py-2 font-medium text-background">{t('awards.year')}</th>
                  <th class="label px-3 py-2 font-medium text-background">{t('awards.film')}</th>
                  <th class="label hidden px-3 py-2 font-medium text-background sm:table-cell">{t('awards.director')}</th>
                </tr>
              </thead>
              <tbody>
                {a.winners.map((w) => (
                  <tr class="border-b border-outline-variant last:border-b-0 hover:bg-film-white">
                    <td class="px-3 py-2 font-mono text-meta-data text-muted">{w.year}</td>
                    <td class="px-3 py-2">
                      {w.tmdbId ? (
                        <a href={`${localizePath(lang, `film/${w.tmdbId}`)}?from=awards`} class="font-display text-headline-md leading-tight text-ink no-underline underline-offset-2 hover:underline">{w.title}</a>
                      ) : (
                        <span class="font-display text-headline-md leading-tight text-ink">{w.title}</span>
                      )}
                      {w.director && <span class="mt-0.5 block font-mono text-meta-data text-muted sm:hidden">{w.director}</span>}
                    </td>
                    <td class="hidden px-3 py-2 font-mono text-meta-data text-charcoal sm:table-cell">{w.director}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      ))
    }
  </section>
</BaseLayout>
