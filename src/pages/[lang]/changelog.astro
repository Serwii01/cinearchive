---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { languages, contentLang, locales, useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { CHANGELOG } from '../../data/changelog';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const dateFmt = new Intl.DateTimeFormat(locales[lang], {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const releases = CHANGELOG.map((r) => ({
  version: r.version,
  date: dateFmt.format(new Date(r.date + 'T00:00:00')),
  title: contentLang(lang) === 'es' ? r.title_es : r.title_en,
  changes: contentLang(lang) === 'es' ? r.changes_es : r.changes_en,
}));
---

<BaseLayout title={t('changelog.title')} description={t('changelog.intro')}>
  <section class="frame py-12">
    <header class="border-b border-ink pb-6">
      <span class="label">v{releases[0].version}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{t('changelog.title')}</h1>
      <p class="mt-4 max-w-2xl text-body-lg text-charcoal">{t('changelog.intro')}</p>
    </header>

    <ol class="mt-10 space-y-10">
      {releases.map((r, i) => (
        <li class="border-l-2 border-ink pl-6">
          <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
            <h2 class="font-display text-headline-lg text-ink">v{r.version}</h2>
            {i === 0 && <span class="label border border-ink bg-ochre px-2 py-1 text-on-accent">{t('changelog.current')}</span>}
            <span class="font-mono text-meta-data text-muted">{r.date}</span>
          </div>
          <p class="mt-1 font-body text-body-lg text-ink">{r.title}</p>
          <ul class="mt-4 space-y-2">
            {r.changes.map((c) => (
              <li class="flex gap-3 text-body-md text-charcoal">
                <span aria-hidden="true" class="mt-1 shrink-0 font-mono text-ochre-dim">—</span>
                <span>{c}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>
