---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import filmsData from '../../data/films.json';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const films = [...filmsData.films].sort((a, b) => a.year - b.year || a.title.localeCompare(b.title));
const intro = t('films.intro').replace('{count}', String(films.length));
---

<BaseLayout
  title={t('films.title')}
  description={intro}
  altPath={localizePath(lang === 'es' ? 'en' : 'es', 'films')}
>
  <section class="frame py-12">
    <header class="border-b border-ink pb-6">
      <span class="label">{t('nav.films')} · {films.length}</span>
      <h1 class="mt-3 text-display-mobile md:text-display-lg">{t('films.title')}</h1>
      <p class="mt-4 max-w-2xl text-body-lg text-charcoal">{intro}</p>

      <input
        id="film-filter"
        type="search"
        placeholder={t('films.search')}
        autocomplete="off"
        class="mt-6 w-full max-w-md border border-ink bg-white px-3 py-2 font-mono text-meta-data text-ink placeholder:text-muted focus:bg-film-white focus:outline-none"
      />
    </header>

    <!-- Tabla de catálogo -->
    <div class="mt-8 overflow-x-auto border border-ink">
      <table class="w-full border-collapse text-left">
        <thead>
          <tr class="border-b border-ink bg-ink text-background">
            <th class="label px-3 py-2 font-medium text-background">·</th>
            <th class="label px-3 py-2 font-medium text-background">{t('films.colTitle')}</th>
            <th class="label hidden px-3 py-2 font-medium text-background md:table-cell">{t('films.colDirector')}</th>
            <th class="label px-3 py-2 font-medium text-background">{t('films.colYear')}</th>
            <th class="label hidden px-3 py-2 font-medium text-background sm:table-cell">{t('films.colCountry')}</th>
            <th class="label hidden px-3 py-2 text-right font-medium text-background lg:table-cell">{t('films.colRuntime')}</th>
          </tr>
        </thead>
        <tbody id="film-rows">
          {
            films.map((f) => (
              <tr
                class="border-b border-outline-variant align-top transition-colors last:border-b-0 hover:bg-film-white"
                data-search={`${f.title} ${f.original_title} ${f.director}`.toLowerCase()}
              >
                <td class="px-3 py-3 text-center font-mono text-meta-data">
                  {f.has_essay ? <span class="text-ochre" title={t('films.hasEssay')}>●</span> : <span class="text-outline-variant">·</span>}
                </td>
                <td class="px-3 py-3">
                  {f.has_essay ? (
                    <a href={localizePath(lang, `archive/${f.essay_pair}`)} class="font-display text-headline-md leading-tight text-ink no-underline hover:text-muted">
                      {f.title}
                    </a>
                  ) : (
                    <span class="font-display text-headline-md leading-tight text-ink">{f.title}</span>
                  )}
                  {f.original_title !== f.title && (
                    <span class="mt-0.5 block font-mono text-meta-data text-muted">{f.original_title}</span>
                  )}
                  <span class="mt-1 block font-mono text-meta-data text-muted md:hidden">{f.director}</span>
                </td>
                <td class="hidden px-3 py-3 font-mono text-meta-data text-charcoal md:table-cell">{f.director}</td>
                <td class="px-3 py-3 font-mono text-meta-data text-charcoal">{f.year}</td>
                <td class="hidden px-3 py-3 font-mono text-meta-data text-charcoal sm:table-cell">{f.country}</td>
                <td class="hidden px-3 py-3 text-right font-mono text-meta-data text-charcoal lg:table-cell">{f.runtime_min}′</td>
              </tr>
            ))
          }
        </tbody>
      </table>
      <p id="film-empty" class="hidden px-3 py-6 font-mono text-body-md text-muted">{t('films.noResults')}</p>
    </div>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('film-filter') as HTMLInputElement | null;
  const rows = Array.from(document.querySelectorAll<HTMLTableRowElement>('#film-rows tr'));
  const empty = document.getElementById('film-empty');

  input?.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    let visible = 0;
    for (const row of rows) {
      const match = !q || (row.dataset.search ?? '').includes(q);
      row.hidden = !match;
      if (match) visible++;
    }
    if (empty) empty.classList.toggle('hidden', visible !== 0);
  });
</script>
