---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalDoc from '../../components/LegalDoc.astro';
import { accessibility } from '../../data/legal';
import { localizePath, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const doc = accessibility[lang];
---

<BaseLayout title={doc.title} description={doc.intro} altPath={localizePath(lang === 'es' ? 'en' : 'es', 'accessibility')}>
  <LegalDoc doc={doc} />
</BaseLayout>
