---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { accessibility, CONTACT_EMAIL } from '../../data/legal';
import { languages, localizePath, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const doc = accessibility[lang];

// Las secciones vienen en orden fijo en los 5 idiomas (ver src/data/legal.ts):
// 0 compromiso · 1 lo que hemos tenido en cuenta · 2 idiomas · 3 limitaciones · 4 contacto.
const [commitment, considered, langsSec, limitations, contact] = doc.sections;

// Correo de contacto para el CTA (la última dirección de la lista).
const primaryEmail = (CONTACT_EMAIL.split('/').pop() ?? CONTACT_EMAIL).trim();

const langMeta = (Object.keys(languages) as Lang[]).map((code) => ({ code, name: languages[code] }));

// Banderas de los idiomas dibujadas a mano (SVG, sin emoji: Windows no renderiza
// los emoji de bandera). El <svg> exterior recorta lo que sobresale del viewBox.
const flags: Record<Lang, string> = {
  es: `<svg viewBox="0 0 60 40" class="h-full w-auto"><rect width="60" height="40" fill="#AA151B"/><rect y="10" width="60" height="20" fill="#F1BF00"/></svg>`,
  en: `<svg viewBox="0 0 60 30" class="h-full w-auto"><clipPath id="uk-c"><path d="M30,15 h30 v15 z v-15 h-30 z h-30 v-15 z v15 h30 z"/></clipPath><rect width="60" height="30" fill="#012169"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 L60,30 M60,0 L0,30" clip-path="url(#uk-c)" stroke="#C8102E" stroke-width="4"/><path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10"/><path d="M30,0 V30 M0,15 H60" stroke="#C8102E" stroke-width="6"/></svg>`,
  gl: `<svg viewBox="0 0 60 40" class="h-full w-auto"><rect width="60" height="40" fill="#fff"/><path d="M0,0 L60,40" stroke="#4A90D9" stroke-width="8"/></svg>`,
  eu: `<svg viewBox="0 0 60 40" class="h-full w-auto"><rect width="60" height="40" fill="#D52B1E"/><path d="M0,0 L60,40 M60,0 L0,40" stroke="#009B48" stroke-width="7"/><path d="M30,0 V40 M0,20 H60" stroke="#fff" stroke-width="7"/></svg>`,
  ca: `<svg viewBox="0 0 60 40" class="h-full w-auto"><rect width="60" height="40" fill="#FCDD09"/><g fill="#DA121A"><rect y="4.444" width="60" height="4.444"/><rect y="13.333" width="60" height="4.444"/><rect y="22.222" width="60" height="4.444"/><rect y="31.111" width="60" height="4.444"/></g></svg>`,
};

// Iconos de línea para la rejilla "qué hemos tenido en cuenta" (mismo orden que el
// texto en legal.ts). Heredan el color con currentColor.
const ICON = 'fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"';
const featureIcons: string[] = [
  `<svg viewBox="0 0 24 24" ${ICON}><path d="M8 6 2 12l6 6M16 6l6 6-6 6"/></svg>`, // HTML semántico </>
  `<svg viewBox="0 0 24 24" ${ICON}><rect x="2" y="6" width="20" height="12" rx="1.5"/><path d="M6 10h.01M10 10h.01M14 10h.01M18 10h.01M8 14h8"/></svg>`, // teclado
  `<svg viewBox="0 0 24 24" ${ICON}><rect x="3" y="4" width="18" height="14" rx="1.5"/><circle cx="8" cy="9" r="1.5"/><path d="M3 15l4-4 4 4 3-3 3 3"/></svg>`, // texto alternativo (imagen)
  `<svg viewBox="0 0 24 24" ${ICON}><circle cx="12" cy="12" r="9"/><path d="M12 3a9 9 0 0 1 0 18Z" fill="currentColor" stroke="none"/></svg>`, // contraste tema claro/oscuro
  `<svg viewBox="0 0 24 24" ${ICON}><rect x="3" y="5" width="12" height="14" rx="1.5"/><rect x="15" y="9" width="6" height="10" rx="1.5"/></svg>`, // responsive
  `<svg viewBox="0 0 24 24" ${ICON}><circle cx="12" cy="12" r="9"/><path d="M9.5 9v6M14.5 9v6"/></svg>`, // menos movimiento (pausa)
  `<svg viewBox="0 0 24 24" ${ICON}><circle cx="9" cy="8" r="3"/><path d="M3.5 19a5.5 5.5 0 0 1 11 0"/><path d="M16 5.5a3 3 0 0 1 0 5M20.5 19a5.5 5.5 0 0 0-3.6-5.2"/></svg>`, // social
];

const warnIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M12 3 2 20h20L12 3Z"/><path d="M12 10v4M12 17h.01"/></svg>`;
---

<BaseLayout title={doc.title} description={doc.intro}>
  <article class="frame py-12">
    {/* ---------- Cabecera ---------- */}
    <header class="border-b-2 border-ink pb-8">
      <div class="flex flex-wrap items-center gap-3">
        <span class="label">{doc.updated}: {doc.date}</span>
        <span class="border border-ink bg-ochre px-2 py-1 font-mono text-meta-data uppercase tracking-widest text-on-accent">
          A11Y
        </span>
      </div>
      <h1 class="mt-4 text-display-mobile md:text-display-lg">{doc.title}</h1>
      <p class="mt-5 max-w-3xl text-body-lg text-charcoal">{doc.intro}</p>
    </header>

    {/* ---------- Compromiso (destacado) ---------- */}
    <section class="mt-10">
      <div class="border-l-4 border-ochre bg-film-white p-6 md:p-8">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <h2 class="font-display text-headline-lg text-ink">{commitment.heading}</h2>
          <span class="shrink-0 border border-ink bg-ink px-3 py-1 font-mono text-meta-data uppercase tracking-widest text-white">
            WCAG 2.1 · AA
          </span>
        </div>
        {commitment.body.map((p) => <p class="mt-3 max-w-2xl text-body-md text-charcoal">{p}</p>)}
      </div>
    </section>

    {/* ---------- Qué hemos tenido en cuenta (rejilla con iconos) ---------- */}
    <section class="mt-14">
      <h2 class="font-display text-headline-lg text-ink">{considered.heading}</h2>
      <ul class="mt-6 grid gap-px border border-ink bg-ink sm:grid-cols-2 lg:grid-cols-3">
        {
          considered.body.map((text, i) => (
            <li class="flex items-start gap-4 bg-surface p-5">
              <span
                class="grid h-10 w-10 shrink-0 place-items-center border border-ink bg-background text-ochre"
                set:html={featureIcons[i % featureIcons.length]}
                aria-hidden="true"
              />
              <p class="text-body-md leading-snug text-charcoal">{text}</p>
            </li>
          ))
        }
      </ul>
    </section>

    {/* ---------- Idiomas (banderas a color) ---------- */}
    <section class="mt-14">
      <h2 class="font-display text-headline-lg text-ink">{langsSec.heading}</h2>
      <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
        {
          langMeta.map(({ code, name }) => (
            <a
              href={localizePath(code, 'accessibility')}
              hreflang={code}
              aria-label={name}
              aria-current={code === lang ? 'page' : undefined}
              class:list={[
                'group flex flex-col items-center gap-3 border-2 p-4 text-center transition-colors',
                code === lang ? 'border-ochre bg-film-white' : 'border-ink hover:bg-surface',
              ]}
            >
              <span
                class="block h-8 overflow-hidden border border-ink shadow-sm transition-transform group-hover:-translate-y-0.5"
                set:html={flags[code]}
                aria-hidden="true"
              />
              <span class="font-display text-headline-md leading-none text-ink">{name}</span>
              <span class="label">{code.toUpperCase()}{code === lang ? ' ·' : ''}</span>
            </a>
          ))
        }
      </div>
      <div class="prose-archive mt-6 max-w-3xl">
        {langsSec.body.slice(1).map((p) => <p>{p}</p>)}
      </div>
    </section>

    {/* ---------- Limitaciones conocidas ---------- */}
    <section class="mt-14">
      <h2 class="font-display text-headline-lg text-ink">{limitations.heading}</h2>
      <ul class="mt-6 grid gap-px border border-outline-variant bg-outline-variant">
        {
          limitations.body.map((text) => (
            <li class="flex items-start gap-3 bg-surface-dim p-5">
              <span class="mt-0.5 shrink-0 text-ochre" set:html={warnIcon} aria-hidden="true" />
              <p class="text-body-md leading-snug text-charcoal">{text}</p>
            </li>
          ))
        }
      </ul>
    </section>

    {/* ---------- Cómo avisarnos (CTA) ---------- */}
    <section class="mt-14">
      <div class="border-2 border-ink bg-ochre p-6 md:p-8">
        <h2 class="font-display text-headline-lg text-on-accent">{contact.heading}</h2>
        {contact.body.map((p) => <p class="mt-3 max-w-2xl text-body-md text-on-accent/85">{p}</p>)}
        <a
          href={`mailto:${primaryEmail}`}
          class="mt-6 inline-flex items-center gap-2 border-2 border-ink bg-ink px-5 py-2.5 font-mono text-meta-data uppercase tracking-widest text-white transition-colors hover:bg-charcoal"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="h-4 w-4" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="1.5"></rect>
            <path d="m3 7 9 6 9-6"></path>
          </svg>
          {primaryEmail}
        </a>
      </div>
    </section>
  </article>
</BaseLayout>
