---
import { getLangFromUrl, useTranslations, localizePath, type Lang } from '../i18n/ui';
import { CURRENT_VERSION } from '../data/changelog';

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-ink bg-charcoal text-background">
  <div class="frame py-10">
    {/* Fila superior: marca + autoría */}
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-display text-headline-md leading-none">{t('site.title')}</p>
        <p class="label mt-2 text-outline-variant">{t('site.tagline')}</p>
      </div>
      <p class="font-mono text-meta-data text-outline-variant">
        © {year} <a href={localizePath(lang, 'sergio')} class="text-outline-variant no-underline hover:text-ochre hover:underline">{t('footer.rights')}</a>
      </p>
    </div>

    {/* Fila inferior: navegación a todo el ancho */}
    <nav class="mt-8 flex flex-wrap gap-x-6 gap-y-3 border-t border-outline pt-6" aria-label="Pie">
      <a href={localizePath(lang)} class="label text-background no-underline hover:text-ochre">{t('nav.home')}</a>
      <a href={localizePath(lang, 'archive')} class="label text-background no-underline hover:text-ochre">{t('nav.archive')}</a>
      <a href={localizePath(lang, 'films')} class="label text-background no-underline hover:text-ochre">{t('nav.films')}</a>
      <a href={localizePath(lang, 'discover')} class="label text-background no-underline hover:text-ochre">{t('nav.discover')}</a>
      <a href={localizePath(lang, 'cines')} class="label text-background no-underline hover:text-ochre">{t('nav.cines')}</a>
      <a href={localizePath(lang, 'about')} class="label text-background no-underline hover:text-ochre">{t('nav.about')}</a>
      <a href={localizePath(lang, 'info')} class="label text-background no-underline hover:text-ochre">{t('nav.info')}</a>
      <a href={localizePath(lang, 'privacy')} class="label text-background no-underline hover:text-ochre">{t('nav.privacy')}</a>
      <a href={localizePath(lang, 'terms')} class="label text-background no-underline hover:text-ochre">{t('nav.terms')}</a>
      <a href={localizePath(lang, 'accessibility')} class="label text-background no-underline hover:text-ochre">{t('nav.accessibility')}</a>
      <a href={localizePath(lang, 'style')} class="label text-background no-underline hover:text-ochre">{t('nav.style')}</a>
      <a href={localizePath(lang, 'changelog')} class="label text-background no-underline hover:text-ochre">{t('nav.changelog')} · v{CURRENT_VERSION}</a>
    </nav>
  </div>
</footer>
