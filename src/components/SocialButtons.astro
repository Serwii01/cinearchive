---
import { useTranslations, type Lang } from '../i18n/ui';
import { enabledSocialProviders } from '../lib/auth';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const hasGoogle = enabledSocialProviders.includes('google');
const hasGithub = enabledSocialProviders.includes('github');
---

{
  (hasGoogle || hasGithub) && (
    <div class="border-t border-ink p-6">
      <p class="label mb-3 text-center">{t('auth.or')}</p>
      <div class="flex flex-col gap-3">
        {hasGoogle && (
          <button type="button" data-social="google" class="btn btn-secondary justify-center">
            <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12.24 10.4v3.42h4.84c-.2 1.25-1.45 3.66-4.84 3.66-2.91 0-5.29-2.41-5.29-5.38s2.38-5.38 5.29-5.38c1.66 0 2.77.71 3.41 1.32l2.32-2.24C16.7 4.02 14.66 3.1 12.24 3.1c-4.86 0-8.8 3.94-8.8 8.8s3.94 8.8 8.8 8.8c5.08 0 8.45-3.57 8.45-8.6 0-.58-.06-1.02-.14-1.46l-8.31-.04z" />
            </svg>
            {t('auth.withGoogle')}
          </button>
        )}
        {hasGithub && (
          <button type="button" data-social="github" class="btn btn-secondary justify-center">
            <svg class="h-5 w-5 shrink-0" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
            </svg>
            {t('auth.withGithub')}
          </button>
        )}
      </div>
    </div>
  )
}
