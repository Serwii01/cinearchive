---
import type { CollectionEntry } from 'astro:content';
import { getLangFromUrl, useTranslations, localizePath, type Lang } from '../i18n/ui';

interface Props {
  entry: CollectionEntry<'articles'>;
  /** índice para numerar la ficha tipo catálogo (#001) */
  index?: number;
}

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { entry, index } = Astro.props;
const d = entry.data;
const href = localizePath(lang, `archive/${d.pair}`);
const ref = index !== undefined ? `#${String(index + 1).padStart(3, '0')}` : '';
---

<article class="group flex h-full flex-col border-t border-ink bg-surface">
  <a href={href} class="flex h-full flex-col no-underline">
    <!-- Cabecera de catálogo -->
    <div class="flex items-center justify-between border-b border-ink px-3 py-2">
      <span class="label">{d.category}</span>
      <span class="font-mono text-meta-data text-muted">{ref}</span>
    </div>

    <!-- Still recortado (placeholder con grano) -->
    <div class="relative aspect-[3/2] overflow-hidden border-b border-ink bg-charcoal">
      {
        d.cover ? (
          <img src={d.cover} alt={d.title} class="h-full w-full object-cover grayscale transition-all duration-300 group-hover:grayscale-0" />
        ) : (
          <div class="film-grain flex h-full w-full items-end p-3">
            <span class="font-display text-headline-lg leading-none text-background/90">{d.year}</span>
          </div>
        )
      }
    </div>

    <!-- Cuerpo -->
    <div class="flex flex-1 flex-col p-3">
      <h3 class="text-headline-md text-ink transition-colors group-hover:text-muted">{d.title}</h3>
      <p class="mt-2 flex-1 text-body-md text-charcoal/80">{d.excerpt}</p>

      <!-- Fila de metadatos en monospace -->
      <dl class="mt-4 grid grid-cols-2 gap-x-3 gap-y-1 border-t border-outline-variant pt-3">
        <div>
          <dt class="label">{t('article.director')}</dt>
          <dd class="font-mono text-meta-data text-ink">{d.director}</dd>
        </div>
        <div class="text-right">
          <dt class="label">{t('article.runtime')}</dt>
          <dd class="font-mono text-meta-data text-ink">{d.runtime}</dd>
        </div>
      </dl>
    </div>
  </a>
</article>
