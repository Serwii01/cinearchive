---
import { localizedField, useTranslations, type Lang } from '../i18n/ui';
import type { Journal } from '../lib/periodicals';

interface Props {
  item: Journal;
  lang: Lang;
}

const { item, lang } = Astro.props;
const t = useTranslations(lang);
const blurb = localizedField(item, 'blurb', lang);
const langLabel = item.lang === 'es' ? 'Español' : 'English';
---

<article class="group flex h-full flex-col bg-surface">
  <a
    href={item.url}
    target="_blank"
    rel="noopener noreferrer nofollow"
    class="flex h-full flex-col no-underline"
  >
    <div class="flex items-center justify-between border-b border-ink px-3 py-2">
      <span class="label">{t('archive.openAccess')}</span>
      <span class="font-mono text-meta-data text-muted">{langLabel}</span>
    </div>

    {/* Portada tipográfica: mismo formato de rejilla que los ejemplares, pero sin
        rehospedar imágenes con copyright (son revistas que enlazan a su web). */}
    <div class="relative aspect-[3/4] overflow-hidden border-b border-ink bg-film-white">
      <div class="flex h-full flex-col items-center justify-center gap-3 px-4 py-6 text-center">
        <span class="font-mono text-meta-data uppercase tracking-[0.12em] text-muted">{item.country}</span>
        <span class="h-px w-8 bg-ink"></span>
        <h3 class="font-display text-headline-lg leading-tight text-ink transition-colors group-hover:text-muted">
          {item.title}
        </h3>
        <p class="font-display text-body-md italic leading-tight text-charcoal">{item.subtitle}</p>
        <span class="mt-1 font-mono text-meta-data text-muted">{t('archive.year')} {item.since}–</span>
      </div>
    </div>

    <div class="flex flex-1 flex-col p-3">
      <p class="line-clamp-3 text-body-md text-charcoal">{blurb}</p>
      <p class="mt-2 font-mono text-meta-data text-muted">{item.publisher}</p>
      <span class="mt-3 inline-flex items-center gap-1 self-start border border-ink px-2 py-1 font-mono text-meta-data text-ink transition-colors group-hover:bg-ink group-hover:text-background">
        {t('archive.openExternal')} <span aria-hidden="true">↗</span>
      </span>
    </div>
  </a>
</article>
