---
import { useTranslations, type Lang } from '../i18n/ui';
import type { Journal } from '../lib/periodicals';

interface Props {
  item: Journal;
  lang: Lang;
}

const { item, lang } = Astro.props;
const t = useTranslations(lang);
const blurb = lang === 'es' ? item.blurb_es : item.blurb_en;
const langLabel = item.lang === 'es' ? 'Español' : 'English';
---

<article class="group flex h-full flex-col border-t border-ink bg-surface">
  <a
    href={item.url}
    target="_blank"
    rel="noopener noreferrer nofollow"
    class="flex h-full flex-col no-underline"
  >
    <div class="flex items-center justify-between border-b border-ink px-3 py-2">
      <span class="label">{t('archive.openAccess')}</span>
      <span class="font-mono text-meta-data text-muted">{langLabel}</span>
    </div>

    <div class="flex flex-1 flex-col p-3">
      <h3 class="font-display text-headline-md leading-tight text-ink transition-colors group-hover:text-muted">
        {item.title}
      </h3>
      <p class="mt-0.5 font-mono text-meta-data text-muted">{item.subtitle}</p>
      <p class="mt-3 text-body-md text-charcoal">{blurb}</p>
      <p class="mt-3 font-mono text-meta-data text-muted">
        {item.publisher} · {item.country} · {t('archive.year')} {item.since}–
      </p>
      <span class="mt-4 inline-flex items-center gap-1 self-start border border-ink px-2 py-1 font-mono text-meta-data text-ink transition-colors group-hover:bg-ink group-hover:text-background">
        {t('archive.openExternal')} <span aria-hidden="true">↗</span>
      </span>
    </div>
  </a>
</article>
