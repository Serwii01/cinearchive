---
import { getLangFromUrl, useTranslations, localizePath, type Lang } from '../i18n/ui';
import LanguageSwitcher from './LanguageSwitcher.astro';
import AuthNav from './AuthNav.astro';
import ThemeToggle from './ThemeToggle.astro';

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const nav = [
  { href: localizePath(lang), label: t('nav.home') },
  { href: localizePath(lang, 'archive'), label: t('nav.archive') },
  { href: localizePath(lang, 'films'), label: t('nav.films') },
  { href: localizePath(lang, 'discover'), label: t('nav.discover') },
];

const current = Astro.url.pathname.replace(/\/$/, '');
const isActive = (href: string) => current === href.replace(/\/$/, '');
---

<header class="border-b border-ink bg-background">
  <div class="frame flex items-stretch justify-between">
    <a href={localizePath(lang)} class="flex min-w-0 flex-col justify-center py-4 no-underline">
      <span class="truncate font-display text-body-lg leading-none text-ink sm:text-headline-md">{t('site.title')}</span>
      <span class="label mt-1 hidden truncate sm:block">{t('site.tagline')}</span>
    </a>

    <div class="flex items-stretch">
      {/* Navegación de escritorio (xl+). Por debajo de 1280 (iPad Pro vertical,
          Nest Hub…) se usa el menú de hamburguesa, más limpio y sin apreturas. */}
      <nav class="hidden items-stretch xl:flex" aria-label="Principal">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'label flex items-center border-l border-ink px-4 no-underline transition-colors hover:bg-ink hover:text-white 2xl:px-5',
                isActive(item.href) && 'bg-ink text-white',
              ]}
            >
              {item.label}
            </a>
          ))
        }
        <AuthNav />
      </nav>

      {/* Controles compactos siempre visibles */}
      <a
        href={localizePath(lang, 'search')}
        aria-label={t('search.title')}
        title={t('search.title')}
        class:list={[
          'flex items-center border-l border-ink px-4 transition-colors hover:bg-ink hover:text-white',
          isActive(localizePath(lang, 'search')) && 'bg-ink text-white',
        ]}
      >
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="16.5" y1="16.5" x2="21" y2="21"></line>
        </svg>
      </a>

      {/* Avatar + notificaciones (se rellenan en cliente si hay sesión con perfil) */}
      <social-nav
        class="contents"
        data-notif={localizePath(lang, 'notifications')}
        data-profile-base={localizePath(lang, 'u')}
        data-notif-label={t('nav.notifications')}
      ></social-nav>

      {/* Idioma y modo oscuro: solo en escritorio; en móvil/tablet van en el menú desplegable */}
      <div class="hidden xl:flex"><ThemeToggle /></div>
      <div class="hidden items-center border-l border-ink px-3 sm:px-4 xl:flex">
        <LanguageSwitcher />
      </div>

      {/* Botón de menú (móvil/tablet, < xl) */}
      <button
        id="nav-toggle"
        type="button"
        aria-label="Menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="flex items-center border-l border-ink px-4 font-mono text-headline-md leading-none transition-colors hover:bg-ink hover:text-white xl:hidden"
      >
        <span data-icon aria-hidden="true">☰</span>
      </button>
    </div>
  </div>

  {/* Menú desplegable (móvil/tablet, < xl) */}
  <nav id="mobile-menu" class="hidden border-t border-ink xl:hidden" aria-label="Principal (móvil)">
    {
      nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'label block border-b border-ink px-4 py-4 no-underline transition-colors hover:bg-ink hover:text-white',
            isActive(item.href) && 'bg-ink text-white',
          ]}
        >
          {item.label}
        </a>
      ))
    }
    <AuthNav mobile />

    {/* Controles que en escritorio van sueltos en la barra */}
    <div class="flex items-center gap-4 px-4 py-4">
      <span class="label text-muted">{t('lang.switch')}</span>
      <LanguageSwitcher align="left" />
      <span class="ml-auto"><ThemeToggle /></span>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const icon = btn?.querySelector('[data-icon]');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    if (icon) icon.textContent = isOpen ? '✕' : '☰';
  });
</script>

<script>
  // Avatar + campana de notificaciones en el navbar. Solo aparece si hay sesión
  // con perfil (username). Una sola llamada alimenta ambos.
  //
  // Para que al cambiar de página en escritorio el avatar NO parpadee
  // (desaparecer y recargar), se cachea el resumen en sessionStorage y se pinta
  // de forma síncrona al cargar; luego se revalida en segundo plano y solo se
  // vuelve a pintar si los datos cambiaron.
  const SUMMARY_KEY = 'cine:social-summary';

  class SocialNav extends HTMLElement {
    connectedCallback() {
      // 1) Pintado inmediato desde caché (evita el hueco vacío en cada navegación).
      let cachedRaw: string | null = null;
      try {
        cachedRaw = sessionStorage.getItem(SUMMARY_KEY);
      } catch {
        /* sessionStorage no disponible */
      }
      if (cachedRaw) {
        try {
          this.render(JSON.parse(cachedRaw));
        } catch {
          /* caché corrupta: se ignora */
        }
      }

      // 2) Revalidación en segundo plano.
      fetch('/api/me/social-summary', { headers: { accept: 'application/json' } })
        .then((res) => (res.ok ? res.json() : null))
        .then((d) => {
          if (!d) return;
          const fresh = JSON.stringify(d);
          if (fresh === cachedRaw) return; // sin cambios: no re-pintar (no recarga el <img>)
          try {
            sessionStorage.setItem(SUMMARY_KEY, fresh);
          } catch {
            /* ignore */
          }
          this.render(d);
        })
        .catch(() => {
          /* silencio: si falla, se mantiene lo pintado desde caché */
        });
    }

    render(d: any) {
      if (!d || !d.authenticated || !d.username) {
        this.innerHTML = ''; // sin sesión o sin perfil
        try {
          sessionStorage.removeItem(SUMMARY_KEY);
        } catch {
          /* ignore */
        }
        return;
      }
      const esc = (s: string) =>
        String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
      const notifUrl = this.dataset.notif!;
      const profileUrl = `${this.dataset.profileBase}/${encodeURIComponent(d.username)}`;
      const label = esc(this.dataset.notifLabel || 'Notifications');
      const n = Number(d.notifications) || 0;
      const badge =
        n > 0
          ? `<span aria-hidden="true" class="absolute right-1.5 top-2 min-w-[16px] border border-ink bg-error px-1 text-center font-mono text-[10px] leading-4 text-white">${n > 99 ? '99+' : n}</span>`
          : '';

      const initials = esc(
        (d.name || d.username || '?').trim().split(/\s+/).slice(0, 2).map((w: string) => w[0]?.toUpperCase() ?? '').join(''),
      );
      const avatarInner = d.hasAvatar
        ? `<img src="/api/avatar/${encodeURIComponent(d.userId)}" alt="" class="h-7 w-7 border border-ink object-cover">`
        : `<span class="inline-flex h-7 w-7 items-center justify-center border border-ink bg-ink font-display text-[11px] leading-none text-white">${initials}</span>`;

      this.innerHTML =
        `<a href="${notifUrl}" aria-label="${label}" title="${label}" class="relative hidden items-center border-l border-ink px-4 transition-colors hover:bg-ink hover:text-white xl:flex">` +
        `<svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="round"><path d="M18 8a6 6 0 1 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.7 21a2 2 0 0 1-3.4 0"></path></svg>` +
        badge +
        `</a>` +
        `<a href="${profileUrl}" aria-label="@${esc(d.username)}" class="flex items-center border-l border-ink px-3 transition-colors hover:bg-ink hover:text-white">${avatarInner}</a>`;
    }
  }
  if (!customElements.get('social-nav')) customElements.define('social-nav', SocialNav);
</script>
