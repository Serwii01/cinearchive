---
import { getLangFromUrl, useTranslations, localizePath, type Lang } from '../i18n/ui';
import LanguageSwitcher from './LanguageSwitcher.astro';
import AuthNav from './AuthNav.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  altPath?: string;
}

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { altPath } = Astro.props;

const nav = [
  { href: localizePath(lang), label: t('nav.home') },
  { href: localizePath(lang, 'archive'), label: t('nav.archive') },
  { href: localizePath(lang, 'films'), label: t('nav.films') },
  { href: localizePath(lang, 'about'), label: t('nav.about') },
];

const current = Astro.url.pathname.replace(/\/$/, '');
const isActive = (href: string) => current === href.replace(/\/$/, '');
---

<header class="border-b border-ink bg-background">
  <div class="frame flex items-stretch justify-between">
    <a href={localizePath(lang)} class="flex min-w-0 flex-col justify-center py-4 no-underline">
      <span class="truncate font-display text-body-lg leading-none text-ink sm:text-headline-md">{t('site.title')}</span>
      <span class="label mt-1 hidden truncate sm:block">{t('site.tagline')}</span>
    </a>

    <div class="flex items-stretch">
      {/* Navegación de escritorio (lg+) */}
      <nav class="hidden items-stretch lg:flex" aria-label="Principal">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'label flex items-center border-l border-ink px-5 no-underline transition-colors hover:bg-ink hover:text-white',
                isActive(item.href) && 'bg-ink text-white',
              ]}
            >
              {item.label}
            </a>
          ))
        }
        <AuthNav />
      </nav>

      {/* Controles compactos siempre visibles */}
      <ThemeToggle />
      <div class="flex items-center border-l border-ink px-3 sm:px-4">
        <LanguageSwitcher altPath={altPath} />
      </div>

      {/* Botón de menú (móvil/tablet) */}
      <button
        id="nav-toggle"
        type="button"
        aria-label="Menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="flex items-center border-l border-ink px-4 font-mono text-headline-md leading-none transition-colors hover:bg-ink hover:text-white lg:hidden"
      >
        <span data-icon aria-hidden="true">☰</span>
      </button>
    </div>
  </div>

  {/* Menú desplegable (móvil/tablet) */}
  <nav id="mobile-menu" class="hidden border-t border-ink lg:hidden" aria-label="Principal (móvil)">
    {
      nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'label block border-b border-ink px-4 py-4 no-underline transition-colors hover:bg-ink hover:text-white',
            isActive(item.href) && 'bg-ink text-white',
          ]}
        >
          {item.label}
        </a>
      ))
    }
    <AuthNav mobile />
  </nav>
</header>

<script>
  const btn = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const icon = btn?.querySelector('[data-icon]');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    if (icon) icon.textContent = isOpen ? '✕' : '☰';
  });
</script>
