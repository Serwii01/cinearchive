---
import type { LegalDoc } from '../data/legal';

interface Props {
  doc: LegalDoc;
}
const { doc } = Astro.props;
---

<section class="frame py-12">
  <header class="border-b border-ink pb-6">
    <span class="label">{doc.updated}: {doc.date}</span>
    <h1 class="mt-3 text-display-mobile md:text-display-lg">{doc.title}</h1>
    <p class="mt-4 max-w-3xl text-body-lg text-charcoal">{doc.intro}</p>
  </header>

  <div class="mx-auto mt-10 max-w-3xl">
    {
      doc.sections.map((s, i) => (
        <section class:list={['py-6', i < doc.sections.length - 1 && 'border-b border-outline-variant']}>
          <h2 class="font-display text-headline-lg text-ink">{s.heading}</h2>
          <div class="prose-archive mt-3">
            {s.body.map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</section>
