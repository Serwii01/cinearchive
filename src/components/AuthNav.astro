---
import { getLangFromUrl, useTranslations, localizePath, type Lang } from '../i18n/ui';

interface Props {
  /** Variante vertical para el menú móvil. */
  mobile?: boolean;
}

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const user = Astro.locals.user;
const { mobile = false } = Astro.props;

const config = {
  initial: user ? 'user' : 'guest',
  mobile,
  links: {
    login: localizePath(lang, 'login'),
    register: localizePath(lang, 'register'),
    account: localizePath(lang, 'account'),
    watchlist: localizePath(lang, 'watchlist'),
    recs: localizePath(lang, 'recommendations'),
    stats: localizePath(lang, 'stats'),
    notifications: localizePath(lang, 'notifications'),
    home: localizePath(lang),
  },
  labels: {
    login: t('nav.login'),
    register: t('nav.register'),
    account: t('nav.account'),
    watchlist: t('nav.watchlist'),
    recs: t('nav.recommendations'),
    stats: t('nav.stats'),
    notifications: t('nav.notifications'),
    logout: t('nav.logout'),
  },
};
---

<auth-nav data-config={JSON.stringify(config)} class:list={[mobile ? 'block' : 'flex items-stretch']}></auth-nav>

<script>
  import { signOut } from '../lib/auth-client';

  class AuthNav extends HTMLElement {
    connectedCallback() {
      const cfg = JSON.parse(this.dataset.config!);
      const m = cfg.mobile;

      // Clases según orientación (horizontal en escritorio, vertical en móvil).
      const base = m
        ? 'label block border-b border-ink px-4 py-4 no-underline transition-colors'
        : 'label flex items-center border-l border-ink px-4 no-underline transition-colors';
      const link = (href: string, label: string, accent = false) =>
        `<a href="${href}" class="${base} ${accent ? 'bg-ochre text-on-accent hover:bg-ink hover:text-white' : 'hover:bg-ink hover:text-white'}">${label}</a>`;

      const renderGuest = () => {
        this.innerHTML = link(cfg.links.login, cfg.labels.login) + link(cfg.links.register, cfg.labels.register, true);
      };
      const renderUser = () => {
        const btnClass = m
          ? 'label block w-full border-b border-ink px-4 py-4 text-left transition-colors hover:bg-ink hover:text-white'
          : 'label flex items-center border-l border-ink px-4 transition-colors hover:bg-ink hover:text-white';
        this.innerHTML =
          // La campana de notificaciones vive en la barra en escritorio; en móvil,
          // como enlace dentro del menú desplegable.
          (m ? link(cfg.links.notifications, cfg.labels.notifications) : '') +
          link(cfg.links.recs, cfg.labels.recs) +
          link(cfg.links.account, cfg.labels.account, true) +
          `<button type="button" data-logout class="${btnClass}">${cfg.labels.logout}</button>`;
        this.querySelector('[data-logout]')?.addEventListener('click', async () => {
          await signOut();
          try { sessionStorage.removeItem('cine:social-summary'); } catch {}
          window.location.href = cfg.links.home;
        });
      };

      // Estado inicial del servidor (correcto en páginas SSR), luego reconciliar.
      cfg.initial === 'user' ? renderUser() : renderGuest();

      fetch('/api/auth/get-session', { headers: { accept: 'application/json' } })
        .then((r) => (r.ok ? r.json() : null))
        .then((data) => {
          const isUser = !!data?.user;
          if (isUser && cfg.initial !== 'user') renderUser();
          else if (!isUser && cfg.initial === 'user') renderGuest();
        })
        .catch(() => {});
    }
  }
  if (!customElements.get('auth-nav')) customElements.define('auth-nav', AuthNav);
</script>
