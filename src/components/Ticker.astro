---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/ui';
import { periodicals } from '../lib/periodicals';

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const entries = periodicals
  .slice()
  .sort((a, b) => b.year - a.year)
  .slice(0, 8)
  .map((p) => `${p.title} (${p.year})`);

const items = entries.length ? entries : [t('site.tagline')];
---

<div class="border-b border-ink bg-ochre text-on-accent">
  <div class="flex items-stretch overflow-hidden">
    <span class="label flex shrink-0 items-center border-r border-ink bg-ink px-3 py-2 text-background">
      {t('ticker.label')}
    </span>
    <div class="marquee flex-1 overflow-hidden py-2">
      <div class="marquee__track">
        {
          [0, 1].map(() => (
            <div class="marquee__group" aria-hidden="false">
              {items.map((it) => (
                <span class="font-mono text-meta-data uppercase tracking-[0.08em]">
                  {it}
                  <span class="mx-4 text-ochre-dim">/</span>
                </span>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>

<style>
  .marquee__track {
    display: flex;
    width: max-content;
    animation: marquee 40s linear infinite;
  }
  .marquee__group {
    display: flex;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .marquee:hover .marquee__track {
    animation-play-state: paused;
  }
  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee__track {
      animation: none;
    }
  }
</style>
