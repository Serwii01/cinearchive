---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/ui';
import { periodicals } from '../lib/periodicals';
import { pdFilms } from '../lib/pdfilms';
import { books } from '../lib/library';
import { collections, collectionTitle } from '../lib/collections';

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Selección repartida de un conjunto, para variedad sin azar en cada carga.
const sample = <T,>(arr: T[], n: number): T[] => {
  if (arr.length <= n) return arr.slice();
  const step = arr.length / n;
  return Array.from({ length: n }, (_, i) => arr[Math.floor(i * step)]);
};

// Mezcla "novedades" de varias secciones para el teletipo.
const periodicalItems = periodicals
  .slice()
  .sort((a, b) => b.year - a.year)
  .slice(0, 4)
  .map((p) => `${p.title} (${p.year})`);
const cinemaItems = sample(pdFilms, 4).map((f) => `${f.title} (${f.year})`);
const bookItems = sample(books, 3).map((b) => b.title);
const collectionItems = collections.slice(0, 3).map((c) => collectionTitle(c, lang));

// Intercala los tipos para que el teletipo no agrupe por sección.
const pools = [periodicalItems, cinemaItems, bookItems, collectionItems];
const mixed: string[] = [];
for (let i = 0; mixed.length < 14; i++) {
  let added = false;
  for (const pool of pools) {
    if (pool[i]) {
      mixed.push(pool[i]);
      added = true;
    }
  }
  if (!added) break;
}

const items = mixed.length ? mixed : [t('site.tagline')];
---

<div class="border-b border-ink bg-ochre text-on-accent">
  <div class="flex items-stretch overflow-hidden">
    <span class="label flex shrink-0 items-center border-r border-ink bg-ink px-3 py-2 text-background">
      {t('ticker.label')}
    </span>
    <div class="marquee flex-1 overflow-hidden py-2">
      <div class="marquee__track">
        {
          [0, 1].map(() => (
            <div class="marquee__group" aria-hidden="false">
              {items.map((it) => (
                <span class="font-mono text-meta-data uppercase tracking-[0.08em]">
                  {it}
                  <span class="mx-4 text-ochre-dim">/</span>
                </span>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>

<style>
  .marquee__track {
    display: flex;
    width: max-content;
    animation: marquee 40s linear infinite;
  }
  .marquee__group {
    display: flex;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .marquee:hover .marquee__track {
    animation-play-state: paused;
  }
  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee__track {
      animation: none;
    }
  }
</style>
