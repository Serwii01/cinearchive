---
interface Props {
  userId: string;
  name: string;
  /** Si el perfil tiene avatar subido (si no, se muestran iniciales). */
  hasAvatar?: boolean;
  /** Tamaño en píxeles (cuadrado). */
  size?: number;
  class?: string;
}

const { userId, name, hasAvatar = false, size = 48, class: cls = '' } = Astro.props;

const initials = (name || '?')
  .trim()
  .split(/\s+/)
  .slice(0, 2)
  .map((w) => w[0]?.toUpperCase() ?? '')
  .join('');
const px = `${size}px`;
---

<span
  class:list={['inline-flex shrink-0 items-center justify-center overflow-hidden border border-ink bg-ink text-white', cls]}
  style={`width:${px};height:${px}`}
  aria-hidden={hasAvatar ? undefined : 'true'}
>
  {hasAvatar ? (
    <img
      src={`/api/avatar/${userId}`}
      alt={name}
      width={size}
      height={size}
      class="h-full w-full object-cover"
      loading="lazy"
    />
  ) : (
    <span class="font-display leading-none" style={`font-size:${Math.round(size * 0.4)}px`}>{initials}</span>
  )}
</span>
