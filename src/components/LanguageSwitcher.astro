---
import { getLangFromUrl, languages, localizePath, useTranslations, type Lang } from '../i18n/ui';

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const langs = Object.keys(languages) as Lang[];

// Las rutas son simétricas entre idiomas: la equivalente se obtiene
// intercambiando el prefijo de la URL actual.
const prefix = new RegExp(`^/(${langs.join('|')})(?=/|$)`);
const pathFor = (target: Lang) =>
  prefix.test(Astro.url.pathname)
    ? Astro.url.pathname.replace(prefix, `/${target}`)
    : localizePath(target);
---

<nav aria-label={t('lang.switch')} class="flex items-stretch">
  {
    langs.map((code) => (
      <a
        href={pathFor(code)}
        hreflang={code}
        title={languages[code]}
        aria-current={code === lang ? 'true' : undefined}
        class:list={[
          'label -ml-px border border-ink px-2 py-2 no-underline transition-colors first:ml-0 hover:bg-ink hover:text-white',
          code === lang && 'bg-ink text-white',
        ]}
      >
        {code.toUpperCase()}
      </a>
    ))
  }
</nav>
