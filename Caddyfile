# TLS automático (Let's Encrypt) para el dominio. {$DOMAIN} y {$EMAIL} llegan por
# variables de entorno desde docker-compose.
{
	email {$EMAIL}
	# Habilita el módulo de rate limiting (imagen construida con Dockerfile.caddy).
	order rate_limit before basic_auth
}

# Redirige www al dominio sin www (requiere que www apunte por A al VPS).
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}

{$DOMAIN} {
	encode gzip zstd

	# --- Protección frente a inundación de peticiones (DoS) ---
	# Límite por IP en el borde, antes de llegar a la app. Dos zonas: una general
	# para toda la web y otra más estricta para la API y el login.
	rate_limit {
		zone general {
			key {remote_host}
			events 240
			window 1m
		}
		zone api {
			match {
				path /api/*
			}
			key {remote_host}
			events 90
			window 1m
		}
	}

	# Rechaza cuerpos de petición desproporcionados (otro vector de abuso).
	request_body {
		max_size 1MB
	}

	# Cabeceras de seguridad (sustituyen a public/_headers de Cloudflare).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
		Cross-Origin-Opener-Policy "same-origin"
		# CSP estricta: scripts y estilos propios; imágenes desde TMDB e Internet
		# Archive; el visor de la hemeroteca se incrusta desde archive.org (frame-src).
		# (No se necesita 'unsafe-inline' en scripts: no hay scripts inline.)
		Content-Security-Policy "default-src 'self'; img-src 'self' https://image.tmdb.org https://archive.org https://*.archive.org data:; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'; frame-src https://archive.org https://*.archive.org https://www.youtube-nocookie.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
		-Server
	}

	# Cache larga para los assets con hash de Astro.
	@assets path /_astro/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	reverse_proxy app:4321
}
